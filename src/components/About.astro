---
---
<section id="about" class="px-8 lg:px-12 py-14 border-b border-slate-100 dark:border-slate-800/50 transition-colors duration-300 bg-white dark:bg-[#0a0f1e]">
  <div class="max-w-3xl">
    <p class="section-num">01 — About</p>
    <h2 class="section-heading text-3xl sm:text-4xl text-slate-900 dark:text-white mb-5">
      Security and privacy<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">
        by design and default.
      </span>
    </h2>
    <div class="space-y-3.5 text-slate-600 dark:text-slate-400 leading-relaxed text-justify text-[15px]">
      <p>I'm a security and privacy focused AI solutions and Modern Workspace consultant with over 10 years of experience aligning technical and security expertise with business needs. I specialise in Microsoft 365 ecosystems — Intune, Exchange Online, Teams, SharePoint, OneDrive, and Microsoft Defender XDR.</p>
      <p>Throughout my career I've enabled organisations to increase their Secure Score by
        <span class="font-semibold text-blue-600 dark:text-blue-400">35–60%</span>
        while reducing operational costs by
        <span class="font-semibold text-blue-600 dark:text-blue-400">25–30%</span>
        through consultation and implementation of cost-efficient solutions that maintain business objectives and security standards.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { icon: '📍', label: 'Location',      value: 'Cottbus, Germany',                   href: null },
        { icon: '🪪', label: 'Residence',     value: 'German Permanent Resident',           href: null },
        { icon: '🎓', label: 'Education',     value: 'BEng (Hons) — London Metropolitan',  href: null },
        { icon: '📧', label: 'Email',         value: 'logan-dinesh@outlook.com',            href: 'mailto:logan-dinesh@outlook.com' },
        { icon: '🏅', label: 'Credentials',  value: '15 Active MS Certs + AWS + ISC2',     href: null },
        { icon: '🔗', label: 'LinkedIn',      value: 'loganathan-dinesh',                   href: 'https://www.linkedin.com/in/loganathan-dinesh' },
      ].map(item => (
        <div class="flex items-start gap-3 p-3.5 rounded-xl bg-slate-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700/50 hover:border-blue-300 dark:hover:border-blue-500/40 transition-colors">
          <span class="text-lg mt-0.5 shrink-0">{item.icon}</span>
          <div class="min-w-0">
            <div class="text-[10px] font-semibold text-slate-400 dark:text-slate-500 mb-0.5 uppercase tracking-widest" style="font-family:'IBM Plex Mono',monospace">{item.label}</div>
            {item.href ? (
              <a href={item.href} target={item.href.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer"
                class="text-[13px] font-semibold text-blue-600 dark:text-blue-400 hover:underline truncate block">{item.value}</a>
            ) : (
              <span class="text-[13px] font-semibold text-slate-800 dark:text-slate-200 truncate block">{item.value}</span>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-5 flex flex-wrap gap-2">
      {[
        { lang: 'English', level: 'C1 — Fluent' },
        { lang: 'German',  level: 'A2 → B1 in progress' },
        { lang: 'Tamil',   level: 'Native' },
      ].map(l => (
        <span class="chip bg-slate-100 dark:bg-slate-800/50 border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400">
          <span class="font-semibold mr-1">{l.lang}</span>
          <span class="opacity-60">{l.level}</span>
        </span>
      ))}
    </div>
  </div>
</section>
