---
const skillGroups = [
  { category: 'Microsoft 365 & Collaboration', icon: '☁️', color: 'blue',
    skills: ['Microsoft Intune','Exchange Online','Microsoft Teams','SharePoint Online','OneDrive','M365 Admin Center','Microsoft Copilot','Endpoint Manager'] },
  { category: 'Identity & Access', icon: '🔐', color: 'indigo',
    skills: ['Microsoft Entra ID','Active Directory (AD DS)','ADFS / SSO','Conditional Access','Zero Trust Architecture','MFA / SSPR','Privileged Identity Mgmt','Global Secure Access'] },
  { category: 'Security & Compliance', icon: '🛡️', color: 'purple',
    skills: ['Microsoft Defender XDR','Defender for Endpoint','Defender for Cloud Apps (CASB)','Microsoft Purview','BitLocker','Information Protection / DLP','ISMS / ISO 27001','Incident Response'] },
  { category: 'Infrastructure & Cloud', icon: '🖥️', color: 'cyan',
    skills: ['Windows Server 2012–2025','Windows 10/11','Azure Cloud','VMware ESXi / vCenter','Hyper-V','DNS / DHCP / RRAS / NPS','Fiber Channel SAN','AWS (Solutions Architect)'] },
  { category: 'Automation & Scripting', icon: '⚡', color: 'green',
    skills: ['PowerShell Scripting','Azure Automation','KQL / Log Analytics','App Packaging & Deployment','Intune Win32 Apps','Process Optimisation'] },
  { category: 'ITSM & Methodology', icon: '📋', color: 'orange',
    skills: ['ITIL Framework','Change Management','Incident & Problem Mgmt','Jira Service Desk','Vulnerability Management','Mentoring & Training','Stakeholder Engagement','Knowledge Base Mgmt'] },
];
const colorMap: Record<string,string> = {
  blue:   'border-blue-200   dark:border-blue-500/30   bg-blue-50/50   dark:bg-blue-500/5',
  indigo: 'border-indigo-200 dark:border-indigo-500/30 bg-indigo-50/50 dark:bg-indigo-500/5',
  purple: 'border-purple-200 dark:border-purple-500/30 bg-purple-50/50 dark:bg-purple-500/5',
  cyan:   'border-cyan-200   dark:border-cyan-500/30   bg-cyan-50/50   dark:bg-cyan-500/5',
  green:  'border-green-200  dark:border-green-500/30  bg-green-50/50  dark:bg-green-500/5',
  orange: 'border-orange-200 dark:border-orange-500/30 bg-orange-50/50 dark:bg-orange-500/5',
};
const pillMap: Record<string,string> = {
  blue:   'bg-blue-100   dark:bg-blue-500/10   text-blue-700   dark:text-blue-300   border-blue-200   dark:border-blue-500/20',
  indigo: 'bg-indigo-100 dark:bg-indigo-500/10 text-indigo-700 dark:text-indigo-300 border-indigo-200 dark:border-indigo-500/20',
  purple: 'bg-purple-100 dark:bg-purple-500/10 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-500/20',
  cyan:   'bg-cyan-100   dark:bg-cyan-500/10   text-cyan-700   dark:text-cyan-300   border-cyan-200   dark:border-cyan-500/20',
  green:  'bg-green-100  dark:bg-green-500/10  text-green-700  dark:text-green-300  border-green-200  dark:border-green-500/20',
  orange: 'bg-orange-100 dark:bg-orange-500/10 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-500/20',
};
---
<section id="skills" class="py-20 px-4 sm:px-6 bg-gray-50 dark:bg-navy-800 transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 text-blue-600 dark:text-blue-400 text-sm font-medium mb-4">Technical Expertise</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">Competencies & Skills</h2>
      <p class="text-gray-500 dark:text-slate-400 mt-3 max-w-xl mx-auto">A decade of hands-on expertise across Microsoft enterprise technologies, security, and cloud infrastructure.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {skillGroups.map(group => (
        <div class={`rounded-xl border p-5 ${colorMap[group.color]} hover:scale-[1.01] transition-transform duration-200`}>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">{group.icon}</span>
            <h3 class="text-sm font-semibold text-gray-700 dark:text-slate-200 uppercase tracking-wider">{group.category}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {group.skills.map(skill => (
              <span class={`px-2.5 py-1 text-xs font-medium rounded-full border ${pillMap[group.color]}`}>{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
