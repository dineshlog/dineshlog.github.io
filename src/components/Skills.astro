---
const groups = [
  { n: 'M365 & Collaboration', color: 'blue',
    skills: ['Microsoft Intune','Exchange Online','Microsoft Teams','SharePoint Online','OneDrive','M365 Admin Center','Microsoft Copilot','Endpoint Manager'] },
  { n: 'Identity & Access', color: 'indigo',
    skills: ['Microsoft Entra ID','Active Directory (AD DS)','ADFS / SSO','Conditional Access','Zero Trust','MFA / SSPR','Privileged Identity Mgmt','Global Secure Access'] },
  { n: 'Security & Compliance', color: 'violet',
    skills: ['Defender XDR','Defender for Endpoint','Defender for Cloud Apps','Microsoft Purview','BitLocker','DLP / Info Protection','ISMS / ISO 27001','Incident Response'] },
  { n: 'Infrastructure & Cloud', color: 'cyan',
    skills: ['Windows Server 2012–2025','Windows 10/11','Microsoft Azure','VMware ESXi / vCenter','Hyper-V / Proxmox','DNS / DHCP / RRAS / NPS','Fiber Channel SAN','AWS (Solutions Architect)'] },
  { n: 'Automation & Scripting', color: 'emerald',
    skills: ['PowerShell Scripting','Azure Automation','KQL / Log Analytics','App Packaging & Deployment','Intune Win32 Apps','Process Optimisation'] },
  { n: 'ITSM & Methodology', color: 'orange',
    skills: ['ITIL Framework','Change Management','Incident & Problem Mgmt','Jira Service Desk','Vulnerability Management','Mentoring & Training','Stakeholder Engagement','Knowledge Base Mgmt'] },
];
const cardCls: Record<string,string> = {
  blue:    'border-blue-200   dark:border-blue-500/20   bg-blue-50/50   dark:bg-blue-500/5   hover:border-blue-300   dark:hover:border-blue-500/40',
  indigo:  'border-indigo-200 dark:border-indigo-500/20 bg-indigo-50/50 dark:bg-indigo-500/5 hover:border-indigo-300 dark:hover:border-indigo-500/40',
  violet:  'border-violet-200 dark:border-violet-500/20 bg-violet-50/50 dark:bg-violet-500/5 hover:border-violet-300 dark:hover:border-violet-500/40',
  cyan:    'border-cyan-200   dark:border-cyan-500/20   bg-cyan-50/50   dark:bg-cyan-500/5   hover:border-cyan-300   dark:hover:border-cyan-500/40',
  emerald: 'border-emerald-200 dark:border-emerald-500/20 bg-emerald-50/50 dark:bg-emerald-500/5 hover:border-emerald-300 dark:hover:border-emerald-500/40',
  orange:  'border-orange-200 dark:border-orange-500/20 bg-orange-50/50 dark:bg-orange-500/5 hover:border-orange-300 dark:hover:border-orange-500/40',
};
const pillCls: Record<string,string> = {
  blue:    'bg-blue-100/80   dark:bg-blue-500/15   border-blue-200   dark:border-blue-500/25   text-blue-800   dark:text-blue-300',
  indigo:  'bg-indigo-100/80 dark:bg-indigo-500/15 border-indigo-200 dark:border-indigo-500/25 text-indigo-800 dark:text-indigo-300',
  violet:  'bg-violet-100/80 dark:bg-violet-500/15 border-violet-200 dark:border-violet-500/25 text-violet-800 dark:text-violet-300',
  cyan:    'bg-cyan-100/80   dark:bg-cyan-500/15   border-cyan-200   dark:border-cyan-500/25   text-cyan-800   dark:text-cyan-300',
  emerald: 'bg-emerald-100/80 dark:bg-emerald-500/15 border-emerald-200 dark:border-emerald-500/25 text-emerald-800 dark:text-emerald-300',
  orange:  'bg-orange-100/80 dark:bg-orange-500/15 border-orange-200 dark:border-orange-500/25 text-orange-800 dark:text-orange-300',
};
---
<section id="skills" class="px-8 lg:px-12 py-14 border-b border-slate-100 dark:border-slate-800/50 transition-colors duration-300 bg-slate-50 dark:bg-[#0c1220] min-h-screen">
  <div data-animate>
    <div class="max-w-3xl mb-8">
    <h2 class="section-heading text-3xl sm:text-4xl text-slate-900 dark:text-white">Competencies & Skills</h2>
    <p class="mt-2.5 text-slate-500 dark:text-slate-400 text-[15px]">A decade of hands-on expertise across Microsoft enterprise technologies, security, and cloud infrastructure.</p>
  </div>
  <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4 max-w-5xl">
    {groups.map(g => (
      <div class={`rounded-2xl border p-5 card-lift transition-colors ${cardCls[g.color]}`}>
        <h3 class="text-[10px] font-semibold tracking-widest uppercase text-slate-600 dark:text-slate-300 mb-3" style="font-family:'IBM Plex Mono',monospace">{g.n}</h3>
        <div class="flex flex-wrap gap-1.5">
          {g.skills.map(s => <span class={`chip ${pillCls[g.color]}`}>{s}</span>)}
        </div>
      </div>
    ))}
  </div>
  </div>
</section>
