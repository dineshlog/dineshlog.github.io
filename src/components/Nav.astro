---
const navLinks = [
  { label: 'About',          href: '#about' },
  { label: 'Skills',         href: '#skills' },
  { label: 'Experience',     href: '#experience' },
  { label: 'Certifications', href: '#certifications' },
  { label: 'Projects',       href: '#projects' },
  { label: 'Education',      href: '#education' },
  { label: 'Contact',        href: '#contact' },
];
---
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/90 dark:bg-navy-900/90 backdrop-blur-md border-b border-gray-200 dark:border-blue-500/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href="#hero" class="flex items-center gap-2 group shrink-0">
        <div class="w-8 h-8 rounded bg-blue-600 flex items-center justify-center text-white font-bold text-sm group-hover:bg-blue-500 transition-colors">DL</div>
        <span class="font-semibold text-gray-900 dark:text-slate-100 hidden sm:block text-sm">Dinesh Loganathan</span>
      </a>

      <div class="hidden lg:flex items-center gap-0.5">
        {navLinks.map(link => (
          <a href={link.href} data-nav-link
            class="nav-link px-2.5 py-1.5 text-sm text-gray-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-500/10 rounded transition-all duration-200">
            {link.label}
          </a>
        ))}
        <a href="/Dinesh_Loganathan_Resume.pdf" download
          class="ml-2 px-3 py-1.5 text-sm border border-blue-500/40 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-500/10 rounded transition-all font-medium">
          Resume
        </a>
        <a href="mailto:logan-dinesh@outlook.com"
          class="ml-1 px-3 py-1.5 text-sm bg-blue-600 hover:bg-blue-500 text-white rounded transition-colors font-medium">
          Hire Me
        </a>
        <button id="theme-toggle" aria-label="Toggle theme"
          class="ml-2 p-2 rounded-lg text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-all">
          <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>
      </div>

      <div class="flex items-center gap-1 lg:hidden">
        <button id="theme-toggle-mobile" aria-label="Toggle theme"
          class="p-2 rounded-lg text-gray-500 dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-all">
          <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>
        <button id="menu-btn" class="p-2 text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white" aria-label="Toggle menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 dark:border-slate-800 bg-white dark:bg-navy-900">
    <div class="px-4 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link px-3 py-2.5 text-sm text-gray-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-500/10 rounded transition-all">{link.label}</a>
      ))}
      <a href="/Dinesh_Loganathan_Resume.pdf" download
        class="mobile-link mt-1 px-4 py-2.5 text-sm text-center border border-blue-500/40 text-blue-600 dark:text-blue-400 rounded font-medium">
        Download Resume
      </a>
      <a href="mailto:logan-dinesh@outlook.com"
        class="mobile-link mt-1 px-4 py-2.5 text-sm text-center bg-blue-600 text-white rounded font-medium">
        Hire Me
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  // Mobile menu toggle — fix #008 aria-expanded
  if (btn && menu) {
    btn.setAttribute('aria-expanded', 'false');
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
    });
  }
  document.querySelectorAll('.mobile-link').forEach(link =>
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    })
  );

  // Theme toggle
  function applyTheme(isDark: boolean) {
    document.documentElement.classList.toggle('dark', isDark);
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }
  ['theme-toggle', 'theme-toggle-mobile'].forEach(id =>
    document.getElementById(id)?.addEventListener('click', () =>
      applyTheme(!document.documentElement.classList.contains('dark'))
    )
  );

  // Scroll-spy — fix #001: avoid toggling dark: prefixed class names in JS
  // Use a plain 'nav-active' sentinel class; CSS handles light/dark colouring
  const sections = document.querySelectorAll('section[id]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => {
          const active = l.getAttribute('href') === '#' + e.target.id;
          l.classList.toggle('nav-active', active);
          l.classList.toggle('font-semibold', active);
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });
  sections.forEach(s => io.observe(s));
</script>
