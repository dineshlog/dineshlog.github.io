---
const jobs = [
  {
    company: 'ESMT Berlin',
    full: 'ESMT GmbH — European School of Management and Technology',
    location: 'Berlin, Germany',
    period: 'Jul 2023 – Present',
    current: true,
    roles: [
      {
        title: 'Information Security Coordinator',
        period: 'Jan 2026 – Present',
        items: [
          'Advising and coordinating the Information Security Management team',
          'Conducting access control reviews, security audits, and incident response planning',
          'Managing vendor security reviews and data protection assessments',
          'Supporting risk assessments, vulnerability mitigation, and security policy development',
          'Coordinating awareness training and compliance reporting',
        ],
      },
      {
        title: 'Microsoft Systems Administrator',
        period: 'Jul 2023 – Present',
        items: [
          'Delivered 7 major IT and security projects over 3 years, significantly improving security posture',
          'Managed full M365 suite: Intune, Exchange Online, Teams, SharePoint, OneDrive, Defender XDR',
          'Owned MDM lifecycle for Windows, macOS, iOS, and Android with Zero Trust and Conditional Access',
          'Improved system health and security posture by 50%; produced management reports',
          'Led ADFS, Global Secure Access (VPN replacement), Defender XDR, and CASB implementations',
          'Mentored junior team members and built a certification-driven learning culture',
        ],
      },
    ],
  },
  {
    company: 'INFARM',
    full: 'INFARM — Indoor Urban Farming GmbH',
    location: 'Berlin, Germany',
    period: 'Jul 2022 – Jun 2023',
    current: false,
    roles: [
      {
        title: 'IT Systems Administrator',
        period: 'Jul 2022 – Jun 2023',
        items: [
          'Administered IT systems for 1,500+ local and international users',
          'Managed Azure AD, Google Workspace, and Intune MDM for 1,200+ devices',
          'Evaluated IAM, security, and compliance; documented and implemented improvements',
          'Implemented auto-provisioning and SSO across Azure AD, Google Workspace, Atlassian, and BambooHR',
          'Contributed to ERP project validation and managed documentation via SharePoint',
        ],
      },
    ],
  },
  {
    company: 'MicroChannel',
    full: 'MicroChannel Private Limited — Managed Service Provider',
    location: 'Australia (remote from Sri Lanka)',
    period: 'Oct 2018 – Jun 2022',
    current: false,
    roles: [
      {
        title: 'Senior Consultant — IT Systems',
        period: 'Oct 2018 – Jun 2022',
        items: [
          'Served 300+ users across 7 offices in Australia and APAC, supporting 1,400+ clients',
          'Delivered Microsoft 365, Azure, Intune MDM, and hybrid Exchange projects end-to-end',
          'Deployed DNS, DHCP, ADFS, RRAS, NPS, and Fiber Channel SAN infrastructure',
          'Led VMware ESXi patching, Exchange 2010→2016 migration, and cloud transition projects',
          'Mentored junior engineers; maintained knowledge base, network diagrams, and change logs',
        ],
      },
    ],
  },
  {
    company: 'Involve 360 / Inbay',
    full: 'Involve 360 (Pvt) Ltd — supporting Inbay Ltd, UK',
    location: 'Sri Lanka (remote NOC)',
    period: 'Aug 2016 – Oct 2018',
    current: false,
    roles: [
      {
        title: 'System Support Engineer — L2/L3',
        period: 'Aug 2016 – Oct 2018',
        items: [
          'Remote infrastructure support for 250+ UK-based MSP clients (200+ users each)',
          '24/7 NOC — proactive monitoring, maintenance, and incident management',
          'Administered M365, Azure, ADDS, DNS, DHCP, RRAS, and File Servers',
          'Executed Office 365 migrations, Azure MFA rollout, and DNS hijacking remediation',
          'Contributed to Intel Spectre/Meltdown VMware ESXi vulnerability remediation project',
        ],
      },
    ],
  },
];
---
<section id="experience" class="px-8 lg:px-12 py-16 border-b border-slate-100 dark:border-slate-800/50
                                 bg-white dark:bg-[#0a0f1e] transition-colors duration-300">
  <div class="max-w-3xl mb-10">
    <p class="section-num">03 — Career</p>
    <h2 class="section-heading text-4xl text-slate-900 dark:text-white">Work Experience</h2>
    <p class="mt-3 text-slate-500 dark:text-slate-400">10+ years across MSP, enterprise, and consulting environments in EMEA and APAC.</p>
  </div>

  <div class="max-w-3xl space-y-0">
    {jobs.map((job, idx) => (
      <div class="relative flex gap-6 pb-10 last:pb-0">
        <!-- Timeline line -->
        <div class="flex flex-col items-center flex-shrink-0">
          <div class={`w-3 h-3 rounded-full mt-1.5 ring-2 ring-offset-2 ring-offset-white dark:ring-offset-[#0a0f1e] ${job.current ? 'bg-blue-500 ring-blue-500' : 'bg-slate-300 dark:bg-slate-600 ring-slate-300 dark:ring-slate-600'}`}></div>
          {idx < jobs.length - 1 && <div class="flex-1 w-px bg-slate-200 dark:bg-slate-800 mt-2"></div>}
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0 pt-0.5">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="font-bold text-slate-900 dark:text-white text-lg" style="font-family:'Syne',sans-serif">{job.company}</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400">{job.full}</p>
              <div class="flex flex-wrap gap-3 mt-1">
                <span class="text-xs font-mono text-slate-400 dark:text-slate-500">📍 {job.location}</span>
                <span class="text-xs font-mono text-slate-400 dark:text-slate-500">⏱ {job.period}</span>
              </div>
            </div>
            {job.current && (
              <span class="chip bg-emerald-50 dark:bg-emerald-500/10 border-emerald-200 dark:border-emerald-500/30 text-emerald-700 dark:text-emerald-400">
                Current
              </span>
            )}
          </div>

          {job.roles.map(role => (
            <div class="mb-4 last:mb-0 pl-4 border-l-2 border-blue-200 dark:border-blue-500/30">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <h4 class="text-sm font-semibold text-blue-600 dark:text-blue-400" style="font-family:'Syne',sans-serif">{role.title}</h4>
                <span class="text-xs font-mono text-slate-400 dark:text-slate-500">{role.period}</span>
              </div>
              <ul class="space-y-1.5">
                {role.items.map(item => (
                  <li class="text-sm text-slate-600 dark:text-slate-400 text-justify flex gap-2">
                    <span class="text-blue-500 shrink-0 mt-0.5">›</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
