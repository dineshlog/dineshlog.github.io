---
<section id="experience" class="px-8 lg:px-12 py-14 border-b border-slate-100 dark:border-slate-800/50 transition-colors duration-300 bg-white dark:bg-[#0a0f1e]">
  <div class="max-w-3xl mb-8">
    <h2 class="section-heading text-3xl sm:text-4xl text-slate-900 dark:text-white">Work Experience</h2>
    <p class="mt-2.5 text-slate-500 dark:text-slate-400 text-[15px]">10+ years across MSP, enterprise, and consulting environments in EMEA and APAC.</p>
  </div>

  <div class="max-w-3xl space-y-4">
    {jobs.map(job => (
      <div class="rounded-2xl bg-white dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700/50 p-6 card-lift shadow-sm dark:shadow-none hover:border-blue-300 dark:hover:border-blue-500/40 transition-colors">
        <!-- Header: company LEFT, period RIGHT -->
        <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white text-[15px] tracking-tight">{job.company}</h3>
            <p class="text-blue-600 dark:text-blue-400 font-semibold text-[13px] mt-0.5">{job.full}</p>
            <p class="text-[11px] text-slate-400 dark:text-slate-500 mt-1" style="font-family:'IBM Plex Mono',monospace">📍 {job.location}</p>
          </div>
          <div class="flex flex-col items-end gap-1.5 shrink-0">
            <span class="chip bg-slate-100 dark:bg-slate-700/50 border-slate-200 dark:border-slate-600/50 text-slate-600 dark:text-slate-300">{job.period}</span>
            {job.current && (
              <span class="chip bg-emerald-50 dark:bg-emerald-500/10 border-emerald-200 dark:border-emerald-500/30 text-emerald-700 dark:text-emerald-400">
                Current
              </span>
            )}
          </div>
        </div>

        <!-- Roles -->
        <div class="border-t border-slate-100 dark:border-slate-700/40 pt-4 space-y-5">
          {job.roles.map(role => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2.5">
                <h4 class="text-[13px] font-bold text-blue-600 dark:text-blue-400">{role.title}</h4>
                <span class="text-[11px] text-slate-400 dark:text-slate-500 shrink-0" style="font-family:'IBM Plex Mono',monospace">{role.period}</span>
              </div>
              <ul class="space-y-2">
                {role.items.map(item => (
                  <li class="text-[13.5px] text-slate-600 dark:text-slate-400 text-justify flex gap-2 leading-relaxed">
                    <span class="text-blue-500 dark:text-blue-400 shrink-0 mt-0.5 font-bold">›</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
