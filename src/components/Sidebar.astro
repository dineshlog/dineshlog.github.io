---
const navLinks = [
  { label: 'About',          href: '#about',          n: '01',
    icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>' },
  { label: 'Competencies',   href: '#skills',         n: '02',
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>' },
  { label: 'Experience',     href: '#experience',     n: '03',
    icon: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>' },
  { label: 'Certifications', href: '#certifications', n: '04',
    icon: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>' },
  { label: 'Projects',       href: '#projects',       n: '05',
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
  { label: 'Education',      href: '#education',      n: '06',
    icon: '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>' },
  { label: 'Contact',        href: '#contact',        n: '07',
    icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>' },
];
const socialLinks = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/loganathan-dinesh',
    icon: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>' },
  { label: 'GitHub',   href: 'https://github.com/dineshlog',
    icon: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>' },
  { label: 'Credly',   href: 'https://credly.com/users/loganathan-dinesh/badges',
    icon: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>' },
  { label: 'Email',    href: 'mailto:logan-dinesh@outlook.com',
    icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>' },
];
---

<!-- ── Mobile top bar ── -->
<header class="lg:hidden fixed top-0 left-0 right-0 z-50 h-14 flex items-center justify-between px-4
               bg-white/95 dark:bg-[#0d1117]/95 backdrop-blur-md
               border-b border-slate-200 dark:border-slate-800/80 shadow-sm dark:shadow-none">
  <a href="#about" class="flex items-center gap-2.5">
    <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center shadow-sm">
      <span class="text-white font-bold text-xs" style="font-family:'IBM Plex Mono',monospace">DL</span>
    </div>
    <span class="font-semibold text-sm text-slate-800 dark:text-slate-100 tracking-tight">Dinesh Loganathan</span>
  </a>
  <div class="flex items-center gap-1">
    <button id="theme-toggle-mobile" aria-label="Toggle theme"
      class="p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
      <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <button id="sidebar-open" aria-label="Open menu" aria-expanded="false"
      class="p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<!-- ── Backdrop ── -->
<div id="sidebar-overlay" class="lg:hidden fixed inset-0 z-40 bg-black/40 backdrop-blur-sm hidden"></div>

<!-- ── Sidebar ── -->
<aside id="sidebar"
  class="fixed top-0 left-0 h-screen z-50 flex flex-col
         w-72
         bg-white dark:bg-[#0d1117]
         border-r border-slate-200 dark:border-slate-800/80
         shadow-xl lg:shadow-none
         -translate-x-full lg:translate-x-0
         transition-transform duration-300 ease-out
         overflow-hidden">

  <!-- Gradient accent bar -->
  <div class="h-[3px] bg-gradient-to-r from-blue-600 via-indigo-500 to-violet-500 flex-shrink-0"></div>

  <!-- Dot texture (dark mode) -->
  <div class="absolute inset-0 top-[3px] sidebar-texture dark:opacity-100 opacity-0 pointer-events-none"></div>

  <div class="relative flex flex-col h-full overflow-y-auto">

    <!-- ── Profile ── -->
    <div class="px-5 pt-6 pb-5 flex flex-col items-center text-center">
      <div class="relative mb-4 sb-1">
        <img src="/ProfilePicture.jpg" alt="Dinesh Loganathan"
          class="w-40 rounded-2xl object-contain shadow-lg ring-2 ring-blue-500/20 block" />
        <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-400 rounded-full border-2 border-white dark:border-[#0d1117]"></span>
      </div>
      <h1 class="sb-2 text-[18px] font-bold text-slate-900 dark:text-white leading-snug tracking-tight mb-0.5">
        Dinesh Loganathan
      </h1>
      <p class="sb-2 text-[11px] font-semibold text-blue-600 dark:text-blue-400 mb-1.5 tracking-wide uppercase" style="font-family:'IBM Plex Mono',monospace">
        BEng (Hons) · M365 Expert
      </p>
      <p class="sb-3 text-[12px] text-slate-500 dark:text-slate-400 leading-relaxed mb-3">
        InfoSec Specialist · Modern Workspace Consultant · Microsoft Certified Trainer
      </p>
      <div class="sb-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full
                  bg-emerald-50 dark:bg-emerald-500/10
                  border border-emerald-200 dark:border-emerald-500/25
                  text-emerald-700 dark:text-emerald-400 text-[11px] font-semibold">
        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
        Open to opportunities
      </div>
    </div>

    <!-- ── Stats ── -->
    <div class="sb-4 mx-4 mb-4 rounded-xl bg-slate-50 dark:bg-slate-800/50
                border border-slate-200 dark:border-slate-700/50 p-3">
      <div class="grid grid-cols-3 divide-x divide-slate-200 dark:divide-slate-700/50 text-center">
        {[
          { v: '10+', l: 'Years' },
          { v: '15',  l: 'Certs' },
          { v: '12+', l: 'Projects' },
        ].map(s => (
          <div class="px-1.5">
            <div class="text-[17px] font-bold text-blue-600 dark:text-blue-400 tracking-tight">{s.v}</div>
            <div class="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5 uppercase tracking-wider" style="font-family:'IBM Plex Mono',monospace">{s.l}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Nav label ── -->
    <div class="mx-4 mb-2 flex items-center gap-2">
      <span class="text-[10px] font-semibold text-slate-400 dark:text-slate-600 tracking-[0.15em] uppercase" style="font-family:'IBM Plex Mono',monospace">Menu</span>
      <div class="flex-1 h-px bg-slate-200 dark:bg-slate-800"></div>
    </div>

    <!-- ── Navigation ── -->
    <nav class="sb-5 px-3 mb-4 flex-1">
      {navLinks.map(link => (
        <a href={link.href} data-nav-link
          class="nav-link group flex items-center gap-3 px-3 py-2 mb-[2px] rounded-lg
                 border-l-2 border-transparent
                 text-slate-600 dark:text-slate-400
                 hover:text-blue-600 dark:hover:text-blue-400
                 hover:bg-blue-50 dark:hover:bg-blue-500/10
                 hover:border-l-blue-400/50
                 transition-all duration-150">
          <span class="text-[10px] tabular-nums text-slate-300 dark:text-slate-700 group-hover:text-blue-400 dark:group-hover:text-blue-600 transition-colors w-5 shrink-0 font-semibold" style="font-family:'IBM Plex Mono',monospace">
            {link.n}
          </span>
          <svg class="w-5 h-5 shrink-0 opacity-60 group-hover:opacity-90 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" set:html={link.icon}></svg>
          <span class="text-[13px] font-medium tracking-tight">{link.label}</span>
        </a>
      ))}
    </nav>

    <!-- ── Bottom ── -->
    <div class="px-4 pb-5 space-y-3">
      <div class="flex items-center gap-0.5">
        {socialLinks.map(s => (
          <a href={s.href} target={s.href.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer"
            title={s.label}
            class="p-2 rounded-lg text-slate-400 dark:text-slate-500
                   hover:text-blue-600 dark:hover:text-blue-400
                   hover:bg-blue-50 dark:hover:bg-blue-500/10
                   transition-all duration-150">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" set:html={s.icon}></svg>
          </a>
        ))}
        <div class="flex-1"></div>
        <button id="theme-toggle" aria-label="Toggle theme"
          class="p-2 rounded-lg text-slate-400 dark:text-slate-500
                 hover:text-blue-600 dark:hover:text-blue-400
                 hover:bg-blue-50 dark:hover:bg-blue-500/10
                 transition-all duration-150">
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>

      <a href="/Dinesh_Loganathan_Resume.pdf" download
        class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-xl
               bg-blue-600 hover:bg-blue-700 active:bg-blue-800
               text-white text-[13px] font-semibold tracking-tight
               shadow-sm shadow-blue-600/20 hover:shadow-blue-600/30
               transition-all duration-200">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download Resume
      </a>

      <p class="text-center text-[10px] text-slate-300 dark:text-slate-700" style="font-family:'IBM Plex Mono',monospace">
        Cottbus, Germany · Permanent Resident
      </p>
    </div>
  </div>
</aside>

<script>
  var panel = document.getElementById('content-panel');

  /* ── Nav link click → scroll content panel ── */
  document.querySelectorAll('[data-nav-link]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var id = link.getAttribute('href').replace('#','');
      var target = document.getElementById(id);
      if (target && panel) {
        e.preventDefault();
        panel.scrollTo({ top: target.offsetTop, behavior: 'smooth' });
      }
      if (window.innerWidth < 1024) closeSidebar();
    });
  });

  /* ── Mobile sidebar drawer ── */
  var sidebar = document.getElementById('sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  var openBtn = document.getElementById('sidebar-open');
  function openSidebar() {
    sidebar.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
    openBtn && openBtn.setAttribute('aria-expanded', 'true');
  }
  function closeSidebar() {
    sidebar.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
    openBtn && openBtn.setAttribute('aria-expanded', 'false');
  }
  openBtn && openBtn.addEventListener('click', openSidebar);
  overlay && overlay.addEventListener('click', closeSidebar);

  /* ── Theme toggle ── */
  function applyTheme(dark) {
    if (dark) document.documentElement.classList.add('dark');
    else document.documentElement.classList.remove('dark');
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
  }
  ['theme-toggle', 'theme-toggle-mobile'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('click', function() {
      applyTheme(!document.documentElement.classList.contains('dark'));
    });
  });

  /* ── Scroll-spy (observes inside content panel) ── */
  var navLinks = document.querySelectorAll('[data-nav-link]');
  if ('IntersectionObserver' in window && panel) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          navLinks.forEach(function(link) {
            link.classList.toggle('nav-active', link.getAttribute('href') === '#' + entry.target.id);
          });
        }
      });
    }, { root: panel, rootMargin: '-20% 0px -70% 0px' });
    document.querySelectorAll('section[id]').forEach(function(s) { io.observe(s); });
  }
</script>
