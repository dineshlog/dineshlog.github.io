---
---
<section id="contact" class="py-20 px-4 sm:px-6 bg-gray-50 dark:bg-navy-800 transition-colors duration-300">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 text-blue-600 dark:text-blue-400 text-sm font-medium mb-4">Contact</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">Let's Connect</h2>
      <p class="text-gray-500 dark:text-slate-400 mt-3 max-w-lg mx-auto">Open to consulting engagements, full-time roles, and collaborations in Microsoft 365, Security, and Modern Workplace.</p>
    </div>
    <div class="grid sm:grid-cols-2 gap-4 mb-8">
      {[
        { icon: '📧', label: 'Email',         value: 'logan-dinesh@outlook.com',        href: 'mailto:logan-dinesh@outlook.com',                         cta: 'Send Email' },
        { icon: '📞', label: 'Phone',         value: '+49 151 19496953',                href: 'tel:+4915119496953',                                       cta: 'Call' },
        { icon: '💼', label: 'LinkedIn',      value: 'linkedin.com/in/loganathan-dinesh', href: 'https://www.linkedin.com/in/loganathan-dinesh',           cta: 'Connect' },
        { icon: '🏅', label: 'Credly Badges', value: 'credly.com/users/loganathan-dinesh', href: 'https://credly.com/users/loganathan-dinesh/badges',    cta: 'View Badges' },
        { icon: '💻', label: 'GitHub',        value: 'github.com/dineshlog',             href: 'https://github.com/dineshlog',                            cta: 'View GitHub' },
        { icon: '📄', label: 'Resume',        value: 'Download PDF',                    href: '/Dinesh_Loganathan_Resume.pdf',                           cta: 'Download' },
      ].map(item => (
        <a href={item.href} target={item.href.startsWith('mailto') || item.href.startsWith('tel') || item.href.startsWith('/') ? '_self' : '_blank'} rel="noopener noreferrer"
          class="bg-white dark:bg-slate-800/60 border border-gray-200 dark:border-slate-700/60 rounded-xl p-5 flex items-center gap-4 hover:border-blue-400 dark:hover:border-blue-500/40 hover:bg-gray-50 dark:hover:bg-slate-800 transition-all group shadow-sm dark:shadow-none">
          <div class="text-3xl shrink-0">{item.icon}</div>
          <div class="flex-1 min-w-0">
            <div class="text-xs text-gray-400 dark:text-slate-500 uppercase tracking-wider">{item.label}</div>
            <div class="text-sm text-gray-800 dark:text-slate-200 font-medium truncate mt-0.5">{item.value}</div>
          </div>
          <span class="text-xs text-blue-600 dark:text-blue-400 group-hover:text-blue-500 dark:group-hover:text-blue-300 shrink-0 font-medium">{item.cta} →</span>
        </a>
      ))}
    </div>
    <div class="bg-blue-50 dark:bg-blue-500/5 border border-blue-200 dark:border-blue-500/20 rounded-xl p-5 text-center">
      <p class="text-gray-700 dark:text-slate-300 text-sm">
        📍 Based in <span class="font-semibold text-gray-900 dark:text-white">Cottbus, Germany</span> · German Permanent Resident ·
        Available for roles in <span class="text-blue-600 dark:text-blue-400">Hamburg, Berlin, remote & hybrid</span>
      </p>
    </div>
  </div>
</section>
