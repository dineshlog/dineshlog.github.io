---
<section id="projects" class="py-20 px-4 sm:px-6 bg-white dark:bg-navy-900 transition-colors duration-300">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 text-blue-600 dark:text-blue-400 text-sm font-medium mb-4">Portfolio</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">Projects Delivered</h2>
      <p class="text-gray-500 dark:text-slate-400 mt-3 max-w-xl mx-auto">End-to-end projects led as architect and delivery lead across enterprise environments.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map(p => (
        <div class={`bg-white dark:bg-slate-800/60 border rounded-xl p-5 flex flex-col transition-all duration-200 hover:-translate-y-0.5 shadow-sm dark:shadow-none ${colorBorder[p.color]}`}>
          <div class="flex items-start justify-between mb-3">
            <span class="text-3xl">{p.icon}</span>
            <span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-slate-700/60 text-gray-600 dark:text-slate-400 rounded-full border border-gray-200 dark:border-slate-600/40">{p.role}</span>
          </div>
          <h3 class="text-base font-bold text-gray-900 dark:text-white mb-0.5">{p.title}</h3>
          <p class="text-xs text-gray-400 dark:text-slate-500 mb-3">{p.subtitle}</p>
          <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed mb-4 flex-1 text-justify">{p.desc}</p>
          <div class="bg-gray-50 dark:bg-slate-900/60 border border-gray-200 dark:border-slate-700/40 rounded-lg p-3 mb-3">
            <span class="text-xs text-gray-400 dark:text-slate-500 uppercase tracking-wider">Outcome</span>
            <p class="text-xs text-gray-700 dark:text-slate-300 mt-0.5 text-justify">{p.outcome}</p>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {p.tags.map(tag => (
              <span class={`px-2 py-0.5 text-xs rounded-full border ${tagColor[p.color]}`}>{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
