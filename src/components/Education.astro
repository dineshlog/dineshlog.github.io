---
---
<section id="education" class="px-8 lg:px-12 py-14 border-b border-slate-100 dark:border-slate-800/50 transition-colors duration-300 bg-slate-50 dark:bg-[#0c1220]">
  <div class="max-w-3xl mb-8">
    <h2 class="section-heading text-3xl sm:text-4xl text-slate-900 dark:text-white">Education</h2>
  </div>
  <div class="max-w-3xl space-y-4">
    {[
      {
        degree: 'BEng (Hons) — Computer Network & Cloud Security',
        institution: 'London Metropolitan University',
        location: 'London, UK',
        period: '2015 – 2018',
        modules: ['Network and Cloud Security','Network Security (CISCO)','Wireless Networks (Cisco)','Network Planning and Simulation'],
      },
      {
        degree: 'Higher National Diploma — ICT System Support',
        institution: 'BTEC EDEXCEL UK',
        location: 'Sri Lanka',
        period: '2009 – 2011',
        modules: ['ICT Systems Support','Networking Infrastructure','IT Service Delivery'],
      },
    ].map(e => (
      <div class="rounded-2xl bg-white dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700/50 p-6 card-lift shadow-sm dark:shadow-none hover:border-blue-300 dark:hover:border-blue-500/40 transition-colors">
        <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white text-[15px] tracking-tight">{e.degree}</h3>
            <p class="text-blue-600 dark:text-blue-400 font-semibold text-[13px] mt-0.5">{e.institution}</p>
          </div>
          <span class="chip bg-slate-100 dark:bg-slate-700/50 border-slate-200 dark:border-slate-600/50 text-slate-600 dark:text-slate-300 shrink-0">{e.period}</span>
        </div>
        <p class="text-[11px] text-slate-400 dark:text-slate-500 mb-2" style="font-family:'IBM Plex Mono',monospace">📍 {e.location} · Key Modules</p>
        <div class="flex flex-wrap gap-1.5">
          {e.modules.map(m => (
            <span class="chip bg-blue-50 dark:bg-blue-500/10 border-blue-200 dark:border-blue-500/25 text-blue-700 dark:text-blue-300">{m}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
