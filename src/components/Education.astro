---
---
<section id="education" class="py-20 px-4 sm:px-6 bg-gray-50 dark:bg-navy-800 transition-colors duration-300">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 text-blue-600 dark:text-blue-400 text-sm font-medium mb-4">Education</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">Academic Background</h2>
    </div>
    <div class="space-y-5">
      {[
        {
          degree: 'BEng (Hons) — Computer Network & Cloud Security',
          institution: 'London Metropolitan University',
          location: 'London, UK',
          period: '2015 – 2018',
          modules: ['Network and Cloud Security','Network Security (CISCO)','Wireless Networks (Cisco)','Network Planning and Simulation'],
          icon: '🎓',
        },
        {
          degree: 'Higher National Diploma — ICT System Support',
          institution: 'BTEC EDEXCEL UK',
          location: 'Sri Lanka',
          period: '2009 – 2011',
          modules: ['ICT Systems Support','Networking Infrastructure','IT Service Delivery'],
          icon: '📚',
        },
      ].map(edu => (
        <div class="bg-white dark:bg-slate-800/60 border border-gray-200 dark:border-slate-700/60 rounded-xl p-6 hover:border-blue-400 dark:hover:border-blue-500/30 transition-colors shadow-sm dark:shadow-none">
          <div class="flex items-start gap-4">
            <div class="text-4xl mt-1">{edu.icon}</div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">{edu.degree}</h3>
              <p class="text-blue-600 dark:text-blue-400 font-medium mt-0.5">{edu.institution}</p>
              <div class="flex flex-wrap gap-3 mt-1.5">
                <span class="text-xs text-gray-400 dark:text-slate-500">📍 {edu.location}</span>
                <span class="text-xs text-gray-400 dark:text-slate-500">🗓 {edu.period}</span>
              </div>
              <div class="mt-3">
                <span class="text-xs text-gray-400 dark:text-slate-500 uppercase tracking-wider">Key Modules</span>
                <div class="flex flex-wrap gap-2 mt-1.5">
                  {edu.modules.map(m => (
                    <span class="px-2.5 py-1 text-xs bg-gray-100 dark:bg-slate-700/60 text-gray-600 dark:text-slate-300 border border-gray-200 dark:border-slate-600/40 rounded-full">{m}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
