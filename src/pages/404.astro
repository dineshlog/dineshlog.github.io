---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="404 – Page Not Found | Dinesh Loganathan">
  <Nav />
  <main class="min-h-screen flex items-center justify-center px-4 bg-gray-50 dark:bg-navy-900 pt-16 transition-colors duration-300">
    <div class="text-center max-w-lg">
      <div class="text-8xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-500 mb-4">404</div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-3">Page not found</h1>
      <p class="text-gray-500 dark:text-slate-400 mb-8 leading-relaxed">
        The page you're looking for doesn't exist or has been moved. Head back to the portfolio to explore my work.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-colors">
          Back to Portfolio
        </a>
        <a href="/#contact" class="px-6 py-3 border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:border-blue-400 dark:hover:border-blue-400 font-semibold rounded-xl transition-colors">
          Get In Touch
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
