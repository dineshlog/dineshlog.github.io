---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 | Dinesh Loganathan Portfolio" description="Page not found.">
  <main class="not-found-wrap">
    <div class="container-shell not-found-card card reveal">
      <p class="eyebrow">404</p>
      <h1>That page is not available</h1>
      <p>
        The link may have changed or the page may have been removed during the redesign.
        Use the options below to continue browsing the portfolio.
      </p>
      <div class="not-found-actions">
        <a href="/" class="action-primary">Back to Home</a>
        <a href="/#contact" class="action-secondary">Go to Contact</a>
      </div>
    </div>
  </main>

  <style>
    .not-found-wrap {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 34px 0;
    }

    .not-found-card {
      width: min(680px, 92vw);
      padding: 26px;
    }

    .not-found-card h1 {
      margin: 12px 0 10px;
      font-family: 'Fraunces', serif;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      line-height: 1.12;
    }

    .not-found-card p {
      margin: 0;
      color: var(--muted);
      font-size: 1rem;
    }

    .not-found-actions {
      margin-top: 22px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    @media (max-width: 640px) {
      .not-found-actions {
        flex-direction: column;
      }

      .not-found-actions a {
        width: 100%;
      }
    }
  </style>
</Layout>