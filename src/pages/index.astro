      grid-template-rows: repeat(3, 1fr);
    }

    .badge-grid-4 {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 1fr;
    }

    .badge-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(201,169,110,0.1);
      border-radius: 14px;
