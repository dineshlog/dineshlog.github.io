    .wallet-tab.active .tab-count {
      background: rgba(201,169,110,0.22);
    }

    .wallet-ext-links {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }

    /* ── Wallet Panes ── */
    .wallet-pane {
      flex: 1;
      min-height: 0;
      display: none;
      flex-direction: column;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.32s cubic-bezier(0.16,1,0.3,1), transform 0.32s cubic-bezier(0.16,1,0.3,1);
      pointer-events: none;
    }

    .wallet-pane.active {
      display: flex;
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .wallet-scroll {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-right: 4px;
    }

    .wallet-scroll::-webkit-scrollbar { display: none; }

    .wallet-group-label {
      margin: 0 0 clamp(8px,1dvh,12px);
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-weight: 600;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .wallet-group-label span {
      background: rgba(201,169,110,0.1);
      color: var(--brand);
      border-radius: 999px;
      padding: 1px 8px;
      font-size: 0.62rem;
      font-weight: 700;
    }

    /* ── Skill Wallet ── */
    .skill-scroll {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(10px,1.4dvh,18px);
      align-content: start;
    }

    .skill-category {
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: clamp(12px,1.6dvh,18px);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .skill-cat-name {
      margin: 0;
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(0.72rem,0.95vw,0.82rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--brand);
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .skill-cat-icon { font-size: 0.9rem; }

    .skill-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .skill-tag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(201,169,110,0.14);
      border-radius: 999px;
      padding: clamp(4px,0.6dvh,6px) clamp(8px,1vw,12px);
      font-size: clamp(0.68rem,0.88vw,0.78rem);
      font-weight: 500;
      color: var(--muted-lt);
