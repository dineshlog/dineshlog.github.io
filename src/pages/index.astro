      font-size: 1rem;
      transition: opacity 0.2s, transform 0.2s;
    }

    .contact-item:hover .contact-arrow { opacity: 0.9; transform: translateX(3px); }

    .footer-line {
      margin: clamp(6px,0.8dvh,10px) 0 0;
      color: var(--muted);
      font-size: 0.72rem;
      opacity: 0.6;
      text-align: center;
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE — tablet
    ═══════════════════════════════════════════ */
    @media (max-width: 1100px) {
