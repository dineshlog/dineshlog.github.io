      .panel-shell { height: auto; }

      .metric-grid { grid-template-columns: repeat(2, 1fr); }
      .expertise-grid { grid-template-columns: 1fr; grid-template-rows: none; gap: 12px; }
      .project-grid { grid-template-columns: repeat(2, 1fr); grid-template-rows: none; }
      .badge-grid-3, .badge-grid-4 { grid-template-columns: repeat(2, 1fr); grid-template-rows: none; }
      .skill-scroll { grid-template-columns: 1fr; }
      .wallet-tabbar { flex-wrap: wrap; gap: 8px; }
      .wallet-ext-links { width: 100%; }
      .contact-grid { grid-template-columns: 1fr; }
      .profile-card { grid-template-columns: 1fr; }
      .profile-dl { grid-template-columns: 1fr; }
      .hero-h1 { font-size: clamp(2.2rem,8vw,3.2rem); }
      .hero-actions { flex-direction: column; }
      .action-primary, .action-secondary { width: 100%; justify-content: center; }
      .timeline { overflow-y: auto; }
      .tl-detail { -webkit-line-clamp: 3; }
      .testimonials-block { flex: none; min-height: 220px; }
      .testim-stage { min-height: 160px; }
      .matrix-svg-wrap { min-height: 260px; }
      .wallet-tabs { flex-wrap: wrap; }
      .sol-cols-3, .sol-cols-2 { grid-template-columns: 1fr; }
    }

    @media (max-width: 400px) {
      .badge-grid-3, .badge-grid-4 { grid-template-columns: 1fr; }
      .project-grid { grid-template-columns: 1fr; }
    }
  </style>
