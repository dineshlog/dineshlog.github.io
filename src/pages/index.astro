    }

    .tab-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(201,169,110,0.12);
      color: var(--brand);
      border-radius: 999px;
      font-size: 0.68rem;
      font-weight: 700;
