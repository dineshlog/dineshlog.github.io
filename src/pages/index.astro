];

const matrixConns: { certId:string; domId:string; path:string; color:string }[] = [];
matrixCerts.forEach(function(cert) {
  cert.doms.forEach(function(domId) {
    const dom = matrixDomains.find(function(d) { return d.id === domId; });
    if (!dom) return;
    const dy = dom.cy - cert.cy;
    const path = 'M' + cert.cx + ',' + cert.cy
      + ' C' + cert.cx + ',' + (cert.cy + dy * 0.5)
      + ' '  + dom.cx  + ',' + (dom.cy - dy * 0.5)
      + ' '  + dom.cx  + ',' + dom.cy;
    matrixConns.push({ certId: cert.id, domId, path, color: dom.color });
  });
});

