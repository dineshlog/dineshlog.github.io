      .primary-nav {
        position: absolute;
        top: calc(100% + 6px);
        right: 4vw; left: 4vw;
        background: rgba(14,20,32,0.97);
        backdrop-filter: blur(20px);
        border: 1px solid var(--line);
        border-radius: 13px;
        padding: 10px;
        display: none;
        flex-direction: column;
        align-items: stretch;
        box-shadow: var(--shadow);
        z-index: 300;
      }

      .primary-nav.is-open { display: flex; }

      .primary-nav a { border-radius: 8px; padding: 10px 14px; }
      .nav-cta { text-align: center; margin-top: 4px; margin-left: 0 !important; }

      .expertise-grid { grid-template-columns: 1fr; grid-template-rows: repeat(4, 1fr); }
      .badge-grid-3 { grid-template-columns: repeat(3, 1fr); }
      .badge-grid-4 { grid-template-columns: repeat(4, 1fr); }
      .contact-grid { grid-template-columns: 1fr; gap: 20px; }
      .scroll-dots { display: none; }
    }

    @media (max-width: 860px) {
      .hero-inner { grid-template-columns: 1fr; gap: 20px; }
      .profile-card {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 16px;
        align-items: start;
      }
