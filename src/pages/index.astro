      flex: 1;
      min-height: 0;
      display: none;
      flex-direction: column;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.32s cubic-bezier(0.16,1,0.3,1), transform 0.32s cubic-bezier(0.16,1,0.3,1);
      pointer-events: none;
    }

    .wallet-pane.active {
