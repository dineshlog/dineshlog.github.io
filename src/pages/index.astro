      transform: translateY(-1px);
    }

    .skill-badge-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(201,169,110,0.15);
      color: var(--brand);
      border-radius: 999px;
      font-size: 0.6rem;
      font-weight: 700;
      padding: 1px 6px;
      min-width: 18px;
      line-height: 1.5;
      transition: background 0.2s;
    }

    .skill-tag:hover .skill-badge-count {
      background: rgba(201,169,110,0.25);
    }

    /* ═══════════════════════════════════════════
       BADGE GRIDS
    ═══════════════════════════════════════════ */
    .cred-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .cred-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      border: 1px solid rgba(201,169,110,0.22);
      color: var(--brand);
      font-size: 0.76rem;
      font-weight: 600;
      border-radius: 999px;
      padding: 6px 14px;
      background: rgba(201,169,110,0.05);
      letter-spacing: 0.02em;
      transition: background 0.2s, border-color 0.2s, transform 0.2s;
    }

    .cred-btn:hover { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.38); transform: translateY(-1px); }

    .badge-grid {
      flex: 1;
      min-height: 0;
      gap: clamp(8px,1dvh,12px);
      display: grid;
    }

    .badge-grid-3 {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 1fr);
    }

    .badge-grid-4 {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 1fr;
    }

    .badge-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(201,169,110,0.1);
      border-radius: 14px;
      padding: clamp(10px,1.3dvh,16px) clamp(8px,1vw,12px) clamp(8px,1dvh,12px);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: clamp(6px,0.8dvh,10px);
      text-align: center;
      overflow: hidden;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s, background 0.3s;
    }

    .badge-card:hover {
      border-color: rgba(201,169,110,0.32);
      box-shadow: 0 0 0 1px rgba(201,169,110,0.08), 0 16px 40px rgba(0,0,0,0.3);
      transform: translateY(-4px);
      background: rgba(201,169,110,0.04);
    }

    .badge-card img {
      width: clamp(48px,6dvh,80px);
      height: clamp(48px,6dvh,80px);
      object-fit: contain;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
      flex-shrink: 0;
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), filter 0.35s;
    }

    .badge-card:hover img {
      transform: scale(1.1) translateY(-2px);
      filter: drop-shadow(0 8px 20px rgba(201,169,110,0.25));
    }

    .badge-label {
      margin: 0;
      font-size: clamp(0.64rem,0.85vw,0.76rem);
      line-height: 1.35;
      color: var(--muted);
      font-weight: 500;
      transition: color 0.3s;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .badge-card:hover .badge-label { color: var(--brand); }

    .badge-sub {
      margin: 0;
      font-size: clamp(0.56rem,0.75vw,0.66rem);
      color: var(--muted);
      opacity: 0.6;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
    }

    /* ═══════════════════════════════════════════
       CONTACT PANEL
    ═══════════════════════════════════════════ */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(32px,5vw,64px);
      align-items: center;
      height: 100%;
    }

    .contact-right {
      display: flex;
      flex-direction: column;
      gap: clamp(8px,1dvh,12px);
    }

    .contact-item {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 2px 12px;
      text-decoration: none;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 11px;
      padding: clamp(10px,1.3dvh,14px) clamp(14px,1.5vw,18px);
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s, background 0.25s;
    }

    .contact-item:hover {
      border-color: rgba(201,169,110,0.25);
      box-shadow: var(--glow-hover);
      transform: translateX(4px);
      background: var(--surface-hover);
    }

    .contact-label {
      grid-column: 1; grid-row: 1;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--brand);
      font-weight: 600;
    }

    .contact-value {
      grid-column: 1; grid-row: 2;
      font-size: clamp(0.8rem,1.1vw,0.9rem);
      font-weight: 600;
      color: var(--text);
      word-break: break-word;
    }

    .contact-arrow {
      grid-column: 2; grid-row: 1 / 3;
      align-self: center;
      color: var(--brand);
      opacity: 0.35;
      font-size: 1rem;
      transition: opacity 0.2s, transform 0.2s;
    }

    .contact-item:hover .contact-arrow { opacity: 0.9; transform: translateX(3px); }

    .footer-line {
      margin: clamp(6px,0.8dvh,10px) 0 0;
      color: var(--muted);
      font-size: 0.72rem;
      opacity: 0.6;
      text-align: center;
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE — tablet
    ═══════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .metric-grid { grid-template-columns: repeat(2, 1fr); }
      .project-grid { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(4, 1fr); }
    }

    @media (max-width: 900px) {
      .menu-toggle { display: flex; }

      .primary-nav {
        position: absolute;
        top: calc(100% + 6px);
        right: 4vw; left: 4vw;
        background: rgba(14,20,32,0.97);
        backdrop-filter: blur(20px);
        border: 1px solid var(--line);
        border-radius: 13px;
        padding: 10px;
        display: none;
        flex-direction: column;
        align-items: stretch;
        box-shadow: var(--shadow);
        z-index: 300;
      }

      .primary-nav.is-open { display: flex; }

      .primary-nav a { border-radius: 8px; padding: 10px 14px; }
      .nav-cta { text-align: center; margin-top: 4px; margin-left: 0 !important; }

      .expertise-grid { grid-template-columns: 1fr; grid-template-rows: repeat(4, 1fr); }
      .badge-grid-3 { grid-template-columns: repeat(3, 1fr); }
      .badge-grid-4 { grid-template-columns: repeat(4, 1fr); }
      .contact-grid { grid-template-columns: 1fr; gap: 20px; }
      .scroll-dots { display: none; }
    }

    @media (max-width: 860px) {
      .hero-inner { grid-template-columns: 1fr; gap: 20px; }
      .profile-card {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 16px;
        align-items: start;
      }
      .profile-photo-wrap { grid-row: 1 / 3; }
      .profile-card img { height: clamp(140px,18dvh,200px); }
      .profile-dl { grid-column: 1 / -1; display: grid; grid-template-columns: repeat(3, 1fr); padding-top: 10px; }
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE — mobile: disable snap, normal scroll
    ═══════════════════════════════════════════ */
    @media (max-width: 640px) {
      html, body { height: auto; overflow: auto; }

      .page-scroll {
        height: auto;
        overflow-y: visible;
        scroll-snap-type: none;
      }

      .snap-panel {
        height: auto;
        min-height: 100dvh;
        scroll-snap-align: none;
        scroll-snap-stop: normal;
        padding: 80px 0 40px;
        justify-content: flex-start;
      }

      .panel-shell { height: auto; }

      .metric-grid { grid-template-columns: repeat(2, 1fr); }
      .expertise-grid { grid-template-columns: 1fr; grid-template-rows: none; gap: 12px; }
      .project-grid { grid-template-columns: repeat(2, 1fr); grid-template-rows: none; }
      .badge-grid-3, .badge-grid-4 { grid-template-columns: repeat(2, 1fr); grid-template-rows: none; }
      .skill-scroll { grid-template-columns: 1fr; }
      .wallet-tabbar { flex-wrap: wrap; gap: 8px; }
      .wallet-ext-links { width: 100%; }
      .contact-grid { grid-template-columns: 1fr; }
      .profile-card { grid-template-columns: 1fr; }
      .profile-dl { grid-template-columns: 1fr; }
      .hero-h1 { font-size: clamp(2.2rem,8vw,3.2rem); }
      .hero-actions { flex-direction: column; }
      .action-primary, .action-secondary { width: 100%; justify-content: center; }
      .timeline { overflow-y: auto; }
      .tl-detail { -webkit-line-clamp: 3; }
    }

    @media (max-width: 400px) {
      .badge-grid-3, .badge-grid-4 { grid-template-columns: 1fr; }
      .project-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
