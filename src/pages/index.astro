    .badge-card:hover .badge-label { color: var(--brand); }

    .badge-sub {
      margin: 0;
      font-size: clamp(0.56rem,0.75vw,0.66rem);
      color: var(--muted);
      opacity: 0.6;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
