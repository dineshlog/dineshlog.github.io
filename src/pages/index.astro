      transition: opacity 0.2s;
    }

    .m-cert circle {
      transition: stroke 0.2s, stroke-width 0.2s, filter 0.2s;
    }

    .m-cert:hover > circle,
    .m-cert.m-highlight > circle {
      stroke: var(--brand);
      stroke-width: 2.5;
      filter: drop-shadow(0 0 6px rgba(201,169,110,0.5));
    }

    .m-cert.m-dim, .m-domain.m-dim { opacity: 0.12; }

    .m-conn { transition: stroke-opacity 0.2s, stroke-width 0.2s; }
    .m-conn.m-dim { stroke-opacity: 0.04 !important; }
    .m-conn.m-highlight { stroke-opacity: 0.85 !important; stroke-width: 2.5 !important; }

    .m-domain rect { transition: filter 0.2s, stroke-opacity 0.2s; }
    .m-domain.m-highlight rect { stroke-opacity: 0.9; }

    .matrix-legend {
      flex-shrink: 0;
      display: flex;
      gap: clamp(10px,2vw,28px);
      justify-content: center;
      flex-wrap: wrap;
    }

    .matrix-legend-item {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: clamp(0.66rem,0.88vw,0.74rem);
      font-weight: 500;
      color: var(--muted);
    }

    .matrix-legend-swatch {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
      opacity: 0.75;
    }

    /* ═══════════════════════════════════════════
       TESTIMONIALS — 3-card grid
    ═══════════════════════════════════════════ */
    .testimonials-block {
      display: flex;
      flex-direction: column;
      gap: clamp(8px,1vw,14px);
    }

    .testim-head { }

    .testim-tagline {
      margin: 2px 0 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.88rem,1.1vw,1.05rem);
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
    }

    .testim-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(12px,1.5vw,20px);
    }

    .testim-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .testim-card:hover {
      border-color: rgba(201,169,110,0.28);
      box-shadow: var(--glow-hover);
      transform: translateY(-3px);
    }

    .testim-frame {
      height: clamp(190px,24vh,280px);
      position: relative;
      overflow: hidden;
      background: rgba(0,0,0,0.2);
    }

    .testim-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
    }

    .testim-ph {
      display: none;
      position: absolute;
      inset: 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px;
      text-align: center;
      background: var(--surface);
    }

    .testim-ph p {
      margin: 0;
      font-size: clamp(0.7rem,0.9vw,0.8rem);
      font-weight: 500;
      color: var(--muted-lt);
    }

    .testim-ph small {
      font-size: 0.58rem;
      color: var(--muted);
      opacity: 0.45;
      line-height: 1.5;
    }

    .testim-card-foot {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 7px;
      padding: clamp(6px,0.8dvh,9px) clamp(10px,1.1vw,14px);
      border-top: 1px solid var(--line-subtle);
      background: rgba(255,255,255,0.012);
    }

    .testim-card-foot span {
      font-size: clamp(0.62rem,0.8vw,0.7rem);
      color: var(--muted);
      font-weight: 500;
    }

    /* ═══════════════════════════════════════════
       EXPERTISE GRID
    ═══════════════════════════════════════════ */
    .expertise-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(16px,2vw,24px);
    }

    .expertise-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: clamp(22px,2.8vw,36px);
      display: flex;
      flex-direction: column;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .expertise-card:hover { border-color: rgba(201,169,110,0.28); box-shadow: var(--glow-hover); transform: translateY(-3px); }

    .expertise-top {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: clamp(8px,1dvh,14px);
      flex-shrink: 0;
    }

    .expertise-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem,5dvh,4.8rem);
      font-weight: 300;
      color: var(--brand);
      opacity: 0.13;
      line-height: 1;
      flex-shrink: 0;
      margin-top: -10px;
      letter-spacing: -0.04em;
      transition: opacity 0.3s;
    }

    .expertise-card:hover .expertise-num { opacity: 0.26; }

    .expertise-card h3 {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1rem,1.6vw,1.25rem);
      font-weight: 600;
      line-height: 1.25;
      color: var(--text);
    }

    .expertise-card > p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.78rem,1vw,0.88rem);
      line-height: 1.6;
      flex-shrink: 0;
    }

    .expertise-card ul {
      margin: clamp(8px,1dvh,12px) 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 6px;
      border-top: 1px solid var(--line-subtle);
      padding-top: clamp(8px,1dvh,12px);
      flex: 1;
      overflow: hidden;
    }

    .expertise-card li {
      position: relative;
      padding-left: 14px;
      color: var(--muted-lt);
      font-size: clamp(0.72rem,0.92vw,0.82rem);
      font-weight: 500;
      line-height: 1.6;
    }

    .expertise-card li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.48rem;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--brand);
      opacity: 0.55;
    }

    /* ═══════════════════════════════════════════
       EXPERIENCE — Vertical Tabs Split Panel
    ═══════════════════════════════════════════ */
    .exp-layout {
      display: grid;
      grid-template-columns: clamp(200px,28%,300px) 1fr;
      gap: 0;
      height: clamp(460px, 60vh, 600px);
      border: 1px solid var(--line);
      border-radius: 16px;
      overflow: hidden;
    }

    .exp-tabs {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--line);
      overflow-y: auto;
      scrollbar-width: none;
      background: rgba(255,255,255,0.01);
    }

    .exp-tab {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: clamp(12px,1.6dvh,18px) clamp(14px,1.5vw,20px);
      border: none;
      border-left: 3px solid transparent;
      border-bottom: 1px solid var(--line-subtle);
      background: transparent;
      text-align: left;
      cursor: pointer;
      position: relative;
      transition: background 0.22s, border-color 0.22s;
    }

    .exp-tab:last-child { border-bottom: none; }

    .exp-tab:hover:not(.active) { background: rgba(201,169,110,0.04); }

    .exp-tab.active {
      background: linear-gradient(90deg, rgba(201,169,110,0.1), rgba(201,169,110,0.04));
      border-left-color: var(--brand);
      box-shadow: inset 0 0 24px rgba(201,169,110,0.03);
    }

    .exp-tab-arrow {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--brand);
      opacity: 0;
      font-size: 1rem;
      transition: opacity 0.22s;
    }

    .exp-tab.active .exp-tab-arrow { opacity: 0.7; }

    .exp-tab-period {
      display: block;
      font-size: clamp(0.56rem,0.72vw,0.62rem);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-weight: 600;
      color: var(--brand);
      opacity: 0.8;
    }

    .exp-tab-title {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.88rem,1.15vw,1.02rem);
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
      margin-top: 1px;
    }

    .exp-tab-co {
      display: block;
      font-size: clamp(0.62rem,0.82vw,0.72rem);
      color: var(--muted);
      margin-top: 2px;
    }

    .exp-detail {
      position: relative;
      overflow: hidden;
    }

    .exp-panel {
      position: absolute;
      inset: 0;
      display: none;
      opacity: 0;
      transform: translateX(12px);
      transition: opacity 0.32s cubic-bezier(0.16,1,0.3,1), transform 0.32s cubic-bezier(0.16,1,0.3,1);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(201,169,110,0.2) transparent;
    }

    .exp-panel.active {
      display: block;
      opacity: 1;
      transform: translateX(0);
    }

    .exp-panel-inner {
      padding: clamp(20px,2.6dvh,32px) clamp(20px,2.4vw,32px);
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: clamp(14px,1.8dvh,22px);
    }

    .exp-panel-head { flex-shrink: 0; }

    .exp-panel-period {
      display: block;
      font-size: clamp(0.58rem,0.75vw,0.65rem);
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-weight: 700;
      color: var(--brand);
      margin-bottom: 6px;
    }

    .exp-panel-title {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.3rem,2.2vw,1.9rem);
      font-weight: 600;
      line-height: 1.15;
      color: var(--text);
    }

    .exp-panel-co {
      margin: 5px 0 0;
      font-size: clamp(0.76rem,1vw,0.88rem);
      color: var(--muted-lt);
      font-weight: 500;
    }

    .exp-bullets {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: clamp(8px,1dvh,12px);
      flex: 1;
      border-top: 1px solid var(--line-subtle);
      padding-top: clamp(14px,1.8dvh,20px);
    }

    .exp-bullets li {
      position: relative;
      padding-left: 18px;
      color: var(--muted);
      font-size: clamp(0.76rem,1vw,0.88rem);
      line-height: 1.6;
    }

    .exp-bullets li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.55rem;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--brand);
      opacity: 0.6;
    }

    /* ═══════════════════════════════════════════
       PROJECT GRID
    ═══════════════════════════════════════════ */
    .project-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(12px,1.5vw,18px);
    }

    .project-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: clamp(12px,1.4dvh,16px);
      display: flex;
      flex-direction: column;
      gap: 6px;
      overflow: hidden;
      position: relative;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .project-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--brand), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .project-card:hover { border-color: rgba(201,169,110,0.28); box-shadow: var(--glow-hover); transform: translateY(-3px); }
    .project-card:hover::before { opacity: 1; }

    .project-card h3 {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.9rem,1.2vw,1.05rem);
      font-weight: 600;
      line-height: 1.25;
      color: var(--text);
      flex-shrink: 0;
    }

    .project-card p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.7rem,0.9vw,0.8rem);
      line-height: 1.6;
      flex: 1;
    }

    .project-stack {
      font-size: clamp(0.62rem,0.8vw,0.7rem);
      color: var(--brand);
      font-weight: 600;
      letter-spacing: 0.02em;
      flex-shrink: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ═══════════════════════════════════════════
       SOLUTIONS — Vertical split-panel
    ═══════════════════════════════════════════ */
    .sol-layout {
      display: grid;
      grid-template-columns: clamp(230px, 30%, 300px) 1fr;
      height: clamp(500px, 65vh, 680px);
      gap: 0;
      border: 1px solid var(--line);
      border-radius: 16px;
      overflow: hidden;
    }

    /* ── Left sidebar ── */
    .sol-sidebar {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--line);
      overflow: hidden;
      background: rgba(255,255,255,0.012);
    }

    .sol-cat-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 3px;
      padding: 8px;
      border-bottom: 1px solid var(--line);
      flex-shrink: 0;
      background: rgba(255,255,255,0.01);
    }

    .sol-cat-btn {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 9px;
      border: none;
      border-radius: 6px;
      background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(0.58rem, 0.76vw, 0.68rem);
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: color 0.2s, background 0.2s;
    }

    .sol-cat-btn.active {
      background: rgba(201,169,110,0.15);
      color: var(--brand);
    }

    .sol-cat-btn:not(.active):hover {
      color: var(--muted-lt);
      background: rgba(255,255,255,0.04);
    }

    .sol-cat-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(201,169,110,0.1);
      color: var(--brand);
      border-radius: 999px;
      font-size: 0.54rem;
      font-weight: 700;
      padding: 1px 5px;
      min-width: 15px;
      line-height: 1.5;
    }

    /* Solution item lists */
    .sol-item-list {
      display: none;
      flex-direction: column;
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      scrollbar-width: none;
    }

    .sol-item-list.active { display: flex; }
    .sol-item-list::-webkit-scrollbar { display: none; }

    .sol-item-tab {
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: clamp(10px,1.3dvh,15px) clamp(12px,1.4vw,18px);
      border: none;
      border-left: 3px solid transparent;
      border-bottom: 1px solid var(--line-subtle);
      background: transparent;
      text-align: left;
      cursor: pointer;
      position: relative;
      transition: background 0.2s, border-left-color 0.2s;
    }

    .sol-item-tab:last-child { border-bottom: none; }

    .sol-item-tab:hover:not(.active) { background: rgba(201,169,110,0.04); }

    .sol-item-tab.active {
      background: linear-gradient(90deg, rgba(201,169,110,0.09), rgba(201,169,110,0.025));
      border-left-color: var(--brand);
    }

    .sol-item-name {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.88rem, 1.1vw, 1.0rem);
      font-weight: 600;
      color: var(--text);
      line-height: 1.25;
    }

    .sol-item-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .sol-item-tag {
      display: inline-flex;
      align-items: center;
      background: rgba(201,169,110,0.05);
      border: 1px solid rgba(201,169,110,0.12);
      color: var(--brand);
      border-radius: 999px;
      padding: 1px 6px;
      font-size: clamp(0.5rem, 0.65vw, 0.58rem);
      font-weight: 600;
      letter-spacing: 0.03em;
      white-space: nowrap;
      opacity: 0.7;
    }

    .sol-item-tab.active .sol-item-tag { opacity: 1; }

    .sol-item-arrow {
      position: absolute;
      right: 11px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--brand);
      opacity: 0;
      font-size: 1rem;
      transition: opacity 0.2s;
    }

    .sol-item-tab.active .sol-item-arrow { opacity: 0.65; }

    /* ── Right detail panel ── */
    .sol-detail-wrap {
      position: relative;
      overflow: hidden;
      background: var(--surface);
    }

    .sol-det-panel {
      position: absolute;
      inset: 0;
      display: none;
      flex-direction: column;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(201,169,110,0.15) transparent;
      opacity: 0;
      transform: translateX(10px);
      transition: opacity 0.26s cubic-bezier(0.16,1,0.3,1), transform 0.26s cubic-bezier(0.16,1,0.3,1);
    }

    .sol-det-panel.active {
      display: flex;
      opacity: 1;
      transform: translateX(0);
    }

    .sol-det-inner {
      padding: clamp(16px,2dvh,24px) clamp(18px,2.2vw,28px);
      display: flex;
      flex-direction: column;
      gap: clamp(12px,1.6dvh,18px);
      min-height: 100%;
    }

    .sol-det-header { flex-shrink: 0; }

    .sol-det-eyebrow {
      display: block;
      font-size: 0.57rem;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-weight: 700;
      color: var(--brand);
      opacity: 0.75;
      margin-bottom: 5px;
    }

    .sol-det-title {
      margin: 0 0 10px;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.25rem, 2vw, 1.8rem);
      font-weight: 600;
      line-height: 1.15;
      color: var(--text);
    }

    .sol-det-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    /* Screenshot */
    .sol-screenshot {
      flex-shrink: 0;
      background: rgba(255,255,255,0.013);
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
      min-height: clamp(120px,16dvh,190px);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .sol-screenshot-ph {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 24px;
      text-align: center;
    }

    .sol-screenshot-ph svg {
      color: var(--brand);
      opacity: 0.18;
      flex-shrink: 0;
    }

    .sol-screenshot-ph p {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.88rem,1.1vw,1.0rem);
      font-weight: 500;
      color: var(--muted);
      opacity: 0.45;
    }

    .sol-screenshot-ph small {
      font-size: 0.54rem;
      color: var(--muted);
      opacity: 0.22;
      letter-spacing: 0.06em;
    }

    .sol-det-desc {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.78rem, 1vw, 0.9rem);
      line-height: 1.75;
    }

    /* External-link solution: open-page card */
    .sol-open-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: clamp(20px,3dvh,30px) 24px;
      border: 1px solid rgba(201,169,110,0.28);
      border-radius: 12px;
      background: rgba(201,169,110,0.04);
      text-decoration: none;
      cursor: pointer;
      transition: background 0.22s, border-color 0.22s, transform 0.18s;
      flex-shrink: 0;
      text-align: center;
    }
    .sol-open-page:hover {
      background: rgba(201,169,110,0.10);
      border-color: rgba(201,169,110,0.55);
      transform: translateY(-2px);
    }
    .sol-open-page-icon {
      color: var(--brand);
      opacity: 0.75;
      display: flex;
    }
    .sol-open-page:hover .sol-open-page-icon { opacity: 1; }
    .sol-open-page-text {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(0.85rem, 1.1vw, 1rem);
      font-weight: 700;
      color: var(--brand);
      letter-spacing: 0.02em;
    }
    .sol-open-page-sub {
      font-size: 0.64rem;
      color: var(--muted);
      opacity: 0.55;
      letter-spacing: 0.04em;
    }

    /* External item marker in sidebar */
    .sol-item-ext-icon {
      color: var(--brand) !important;
      opacity: 0.7;
      font-size: 0.82rem !important;
    }
    .sol-item-ext:hover .sol-item-ext-icon { opacity: 1; }

    /* sol-tag: shared by item list + detail header */
    .sol-tag {
      display: inline-flex;
      align-items: center;
      background: rgba(201,169,110,0.06);
      border: 1px solid rgba(201,169,110,0.16);
      color: var(--brand);
      border-radius: 999px;
      padding: 2px 9px;
      font-size: clamp(0.6rem,0.78vw,0.68rem);
      font-weight: 600;
      letter-spacing: 0.03em;
      white-space: nowrap;
    }

    /* ═══════════════════════════════════════════
       WALLET TABS
    ═══════════════════════════════════════════ */
    .wallet-tabbar {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      flex-shrink: 0;
      border-bottom: 1px solid var(--line);
      margin-bottom: clamp(10px,1.4dvh,16px);
    }

    .wallet-tabs {
      display: flex;
      gap: 0;
    }

    .wallet-tab {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: clamp(8px,1dvh,11px) clamp(12px,1.3vw,17px);
      border: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(0.75rem,1vw,0.84rem);
      font-weight: 600;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: color 0.22s, border-bottom-color 0.22s;
      border-radius: 0;
      position: relative;
    }

    .wallet-tab svg { flex-shrink: 0; opacity: 0.55; transition: opacity 0.22s; }

    .wallet-tab.active {
      color: var(--brand);
      border-bottom-color: var(--brand);
      background: transparent;
    }

    .wallet-tab.active svg { opacity: 1; }

    .wallet-tab:not(.active):hover {
      color: var(--muted-lt);
      background: transparent;
    }

    .tab-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(201,169,110,0.1);
      color: var(--brand);
      border-radius: 999px;
      font-size: 0.65rem;
      font-weight: 700;
      padding: 1px 7px;
      min-width: 20px;
      line-height: 1.6;
      transition: background 0.22s;
    }

    .wallet-tab.active .tab-count {
      background: rgba(201,169,110,0.18);
    }

    .wallet-ext-links {
      display: flex;
      gap: 8px;
      flex-shrink: 0;
    }

    /* ── Wallet Panes ── */
    .wallet-pane {
      display: none;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.32s cubic-bezier(0.16,1,0.3,1), transform 0.32s cubic-bezier(0.16,1,0.3,1);
      pointer-events: none;
    }

    .wallet-pane.active {
      display: block;
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .wallet-scroll {
      padding-right: 4px;
    }

    .wallet-group-label {
      margin: 0 0 clamp(8px,1dvh,12px);
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-weight: 600;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .wallet-group-label span {
      background: rgba(201,169,110,0.1);
      color: var(--brand);
      border-radius: 999px;
      padding: 1px 8px;
      font-size: 0.62rem;
      font-weight: 700;
    }

    /* ── Skill Wallet ── */
    .skill-scroll {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(12px,1.6vw,20px);
      align-content: start;
      margin-top: 2px;
    }

    .skill-category {
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: clamp(12px,1.6dvh,18px);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .skill-cat-name {
      margin: 0;
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(0.72rem,0.95vw,0.82rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--brand);
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .skill-cat-icon { font-size: 0.9rem; }

    .skill-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .skill-tag {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(201,169,110,0.14);
      border-radius: 999px;
      padding: clamp(4px,0.6dvh,6px) clamp(8px,1vw,12px);
      font-size: clamp(0.68rem,0.88vw,0.78rem);
      font-weight: 500;
      color: var(--muted-lt);
      cursor: default;
      transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.2s;
      white-space: nowrap;
    }

    .skill-tag:hover {
      background: rgba(201,169,110,0.08);
      border-color: rgba(201,169,110,0.3);
      color: var(--text);
      transform: translateY(-1px);
    }

    .skill-badge-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(201,169,110,0.15);
      color: var(--brand);
      border-radius: 999px;
      font-size: 0.6rem;
      font-weight: 700;
      padding: 1px 6px;
      min-width: 18px;
      line-height: 1.5;
      transition: background 0.2s;
    }

    .skill-tag:hover .skill-badge-count {
      background: rgba(201,169,110,0.25);
    }

    /* ═══════════════════════════════════════════
       BADGE GRIDS
    ═══════════════════════════════════════════ */
    .cred-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .cred-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      border: 1px solid rgba(201,169,110,0.22);
      color: var(--brand);
      font-size: 0.76rem;
      font-weight: 600;
      border-radius: 999px;
      padding: 6px 14px;
      background: rgba(201,169,110,0.05);
      letter-spacing: 0.02em;
      transition: background 0.2s, border-color 0.2s, transform 0.2s;
    }

    .cred-btn:hover { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.38); transform: translateY(-1px); }

    .badge-grid {
      gap: clamp(10px,1.3vw,16px);
      display: grid;
      margin-bottom: clamp(20px,2.5vh,32px);
    }

    .badge-grid-3 {
      grid-template-columns: repeat(3, 1fr);
    }

    .badge-grid-4 {
      grid-template-columns: repeat(4, 1fr);
    }

    .badge-card {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(201,169,110,0.1);
      border-radius: 14px;
      padding: clamp(10px,1.3dvh,16px) clamp(8px,1vw,12px) clamp(8px,1dvh,12px);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: clamp(6px,0.8dvh,10px);
      text-align: center;
      overflow: hidden;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s, background 0.3s;
    }

    .badge-card:hover {
      border-color: rgba(201,169,110,0.28);
      box-shadow: var(--glow-hover);
      transform: translateY(-3px);
      background: rgba(201,169,110,0.04);
    }

    .badge-card img {
      width: clamp(58px,6dvh,96px);
      height: clamp(58px,6dvh,96px);
      object-fit: contain;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
      flex-shrink: 0;
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), filter 0.35s;
    }

    .badge-card:hover img {
      transform: scale(1.1) translateY(-2px);
      filter: drop-shadow(0 8px 20px rgba(201,169,110,0.25));
    }

    .badge-label {
      margin: 0;
      font-size: clamp(0.64rem,0.85vw,0.76rem);
      line-height: 1.35;
      color: var(--muted);
      font-weight: 500;
      transition: color 0.3s;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .badge-card:hover .badge-label { color: var(--brand); }

    .badge-sub {
      margin: 0;
      font-size: clamp(0.56rem,0.75vw,0.66rem);
      color: var(--muted);
      opacity: 0.6;
      font-weight: 500;
      letter-spacing: 0.02em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
    }

    /* ═══════════════════════════════════════════
       CONTACT PANEL
    ═══════════════════════════════════════════ */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(32px,5vw,64px);
      align-items: center;
      position: relative;
    }

    .contact-grid::before {
      content: '';
      position: absolute;
      top: -120px;
      left: -80px;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(ellipse at center, rgba(201,169,110,0.07), transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .contact-left, .contact-right { position: relative; z-index: 1; }

    .contact-right {
      display: flex;
      flex-direction: column;
      gap: clamp(8px,1dvh,12px);
    }

    .contact-item {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 2px 12px;
      text-decoration: none;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 11px;
      padding: clamp(10px,1.3dvh,14px) clamp(14px,1.5vw,18px);
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s, background 0.25s;
    }

    .contact-item:hover {
      border-color: rgba(201,169,110,0.25);
      box-shadow: var(--glow-hover);
      transform: translateX(4px);
      background: var(--surface-hover);
    }

    .contact-label {
      grid-column: 1; grid-row: 1;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--brand);
      font-weight: 600;
    }

    .contact-value {
      grid-column: 1; grid-row: 2;
      font-size: clamp(0.8rem,1.1vw,0.9rem);
      font-weight: 600;
      color: var(--text);
      word-break: break-word;
    }

    .contact-arrow {
      grid-column: 2; grid-row: 1 / 3;
      align-self: center;
      color: var(--brand);
      opacity: 0.35;
      font-size: 1rem;
      transition: opacity 0.2s, transform 0.2s;
    }

    .contact-item:hover .contact-arrow { opacity: 0.9; transform: translateX(3px); }

    .footer-line {
      margin: clamp(6px,0.8dvh,10px) 0 0;
      color: var(--muted);
      font-size: 0.72rem;
      opacity: 0.6;
      text-align: center;
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE — large tablet
    ═══════════════════════════════════════════ */
    @media (max-width: 1100px) {
      .metric-grid { grid-template-columns: repeat(2, 1fr); }
      .project-grid { grid-template-columns: repeat(3, 1fr); }
      .badge-grid-3 { grid-template-columns: repeat(3, 1fr); }
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE — tablet
    ═══════════════════════════════════════════ */
    @media (max-width: 900px) {
      .menu-toggle { display: flex; }

      .primary-nav {
        position: absolute;
        top: calc(100% + 6px);
        right: 4vw; left: 4vw;
        background: rgba(14,20,32,0.97);
        backdrop-filter: blur(20px);
        border: 1px solid var(--line);
        border-radius: 13px;
        padding: 10px;
        display: none;
        flex-direction: column;
        align-items: stretch;
        box-shadow: var(--shadow);
        z-index: 300;
      }

      .primary-nav.is-open { display: flex; }
      .primary-nav a { border-radius: 8px; padding: 10px 14px; }
      .nav-cta { text-align: center; margin-top: 4px; margin-left: 0 !important; }

      .expertise-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; gap: 32px; }
      .scroll-dots { display: none; }
      .exp-layout { height: clamp(380px, 55vh, 520px); }
      .sol-layout { height: clamp(440px, 58vh, 580px); }
    }

    @media (max-width: 860px) {
      .hero-inner { grid-template-columns: 1fr; gap: 24px; }
      .profile-card {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 16px;
        align-items: start;
      }
      .profile-photo-wrap { grid-row: 1 / 3; }
      .profile-card img { height: clamp(140px,18dvh,200px); }
      .profile-dl { grid-column: 1 / -1; display: grid; grid-template-columns: repeat(3, 1fr); padding-top: 10px; }
    }

    /* ═══════════════════════════════════════════
       RESPONSIVE — mobile
    ═══════════════════════════════════════════ */
    @media (max-width: 640px) {
      .snap-panel { padding: 80px 0 52px; }
      .hero-panel { padding-top: 80px; padding-bottom: 40px; }

      .metric-grid { grid-template-columns: repeat(2, 1fr); }
      .expertise-grid { grid-template-columns: 1fr; gap: 14px; }
      .project-grid { grid-template-columns: repeat(2, 1fr); }
      .badge-grid-3, .badge-grid-4 { grid-template-columns: repeat(2, 1fr); }
      .skill-scroll { grid-template-columns: 1fr; }
      .testim-cards { grid-template-columns: 1fr; }

      .wallet-tabbar { flex-wrap: wrap; gap: 8px; border-bottom: none; }
      .wallet-tabs { border-bottom: 1px solid var(--line); width: 100%; flex-wrap: wrap; }
      .wallet-tab { border-radius: 0; }
      .wallet-ext-links { width: 100%; }

      .contact-grid { grid-template-columns: 1fr; }
      .profile-card { grid-template-columns: 1fr; }
      .profile-dl { grid-template-columns: 1fr; }
      .hero-h1 { font-size: clamp(2.2rem,8vw,3.2rem); }
      .hero-actions { flex-direction: column; }
      .action-primary, .action-secondary { width: 100%; justify-content: center; }

      .exp-layout { grid-template-columns: 1fr; height: auto; }
      .exp-tabs { max-height: 200px; overflow-y: auto; }
      .exp-detail { position: relative; min-height: 340px; }
      .exp-panel { position: relative; }

      .sol-layout { grid-template-columns: 1fr; height: auto; border-radius: 12px; }
      .sol-sidebar { border-right: none; border-bottom: 1px solid var(--line); max-height: 200px; overflow-y: auto; }
      .sol-detail-wrap { min-height: 320px; }
      .sol-det-panel { position: relative; inset: auto; opacity: 1; transform: none; min-height: 320px; }
      .sol-det-panel:not(.active) { display: none; }

      .matrix-outer { height: clamp(300px, 45vh, 420px); }
    }

    @media (max-width: 400px) {
      .badge-grid-3, .badge-grid-4 { grid-template-columns: 1fr; }
      .project-grid { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
