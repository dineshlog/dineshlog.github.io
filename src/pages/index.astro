    }

    /* ═══════════════════════════════════════════
       BADGE GRIDS
    ═══════════════════════════════════════════ */
    .cred-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .cred-btn {
      display: inline-flex;
      align-items: center;
