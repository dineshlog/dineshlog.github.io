---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { id: 'profile', label: 'Profile' },
  { id: 'expertise', label: 'Expertise' },
  { id: 'experience', label: 'Experience' },
  { id: 'projects', label: 'Projects' },
  { id: 'credentials', label: 'Credentials' },
  { id: 'contact', label: 'Contact' },
];

const keyMetrics = [
  { value: '10+', label: 'Years in IT, security, and modern workplace delivery' },
  { value: '35–60%', label: 'Secure Score uplift delivered in transformation programs' },
  { value: '25–30%', label: 'Operational cost reduction through platform consolidation' },
  { value: '1,500+', label: 'International users supported across enterprise operations' },
];

const expertiseAreas = [
  {
    title: 'Microsoft 365 & Endpoint Engineering',
    summary: 'Architecture and administration of Intune, Exchange Online, Teams, SharePoint, OneDrive, and M365 platform governance.',
    points: ['Intune MDM lifecycle', 'Exchange hybrid + cloud', 'Teams and SharePoint governance', 'Endpoint compliance at scale'],
  },
  {
    title: 'Identity, Access & Zero Trust',
    summary: 'Identity-first security controls with Entra ID, Conditional Access, MFA/SSPR, and federation hardening for distributed teams.',
    points: ['Conditional Access strategy', 'SSO and federation', 'Least privilege and access reviews', 'Global Secure Access rollout'],
  },
  {
    title: 'Security Operations & Compliance',
    summary: 'Defender XDR and Purview implementations aligned to practical risk reduction, compliance readiness, and incident response maturity.',
    points: ['Defender XDR implementation', 'Data protection and DLP', 'Vendor security and audits', 'Risk remediation planning'],
  },
  {
    title: 'Automation & Service Reliability',
    summary: 'Process redesign with PowerShell and Azure automation to reduce manual work, accelerate response, and improve consistency.',
    points: ['PowerShell orchestration', 'Runbooks and reporting', 'ITSM and change discipline', 'Knowledge transfer and mentoring'],
  },
];

const timeline = [
  {
    period: '2026 – Present',
    title: 'Information Security Coordinator',
    company: 'ESMT GmbH, Berlin',
    detail: 'Coordinate ISMS activities, security reviews, access governance, vendor risk assessments, and awareness initiatives across the organization.',
  },
  {
    period: '2023 – Present',
    title: 'Microsoft Systems Administrator',
    company: 'ESMT GmbH, Berlin',
    detail: 'Led multiple M365 and security programs including Global Secure Access, Defender stack expansion, and cross-platform endpoint governance.',
  },
  {
    period: '2022 – 2023',
    title: 'IT Systems Administrator',
    company: 'INFARM, Berlin',
    detail: 'Managed identity, endpoint, and SaaS operations for a global workforce and improved provisioning, SSO, and compliance workflows.',
  },
  {
    period: '2018 – 2022',
    title: 'Senior Consultant – IT Systems',
    company: 'MicroChannel (Australia / APAC)',
    detail: 'Delivered enterprise Microsoft, Azure, Exchange, virtualization, and infrastructure programs for MSP clients at regional scale.',
  },
  {
    period: '2016 – 2018',
    title: 'System Support Engineer L2/L3',
    company: 'Involve 360 / Inbay (UK NOC)',
    detail: 'Provided 24/7 remote support for MSP environments covering migrations, security remediation, and infrastructure operations.',
  },
];

const projects = [
  {
    name: 'Global Secure Access Program',
    result: 'Legacy VPN replaced with identity-centric secure access and policy-driven controls.',
    stack: 'Entra ID · Conditional Access · Zero Trust',
  },
  {
    name: 'Defender XDR Security Consolidation',
    result: 'Unified endpoint, identity, and cloud signals into one incident response workflow.',
    stack: 'Defender for Endpoint · Identity · Cloud Apps',
  },
  {
    name: 'Purview Information Protection',
    result: 'Rolled out classification, retention, and DLP governance for regulated collaboration.',
    stack: 'Purview · Sensitivity Labels · Compliance',
  },
  {
    name: 'VMware to Proxmox Migration',
    result: 'Completed platform migration without service interruption while reducing licensing cost.',
    stack: 'VMware ESXi · Proxmox VE · Infrastructure Ops',
  },
  {
    name: 'Enterprise Intune MDM Rollout',
    result: 'Standardized secure endpoint lifecycle across Windows, macOS, iOS, and Android.',
    stack: 'Microsoft Intune · Baselines · App Deployment',
  },
  {
    name: 'Automation & Reporting Framework',
    result: 'Reduced repetitive admin effort through scripted provisioning and compliance reporting.',
    stack: 'PowerShell · Azure Automation · Log Analytics',
  },
];

const certifications = [
  { label: 'Security, Compliance, and Identity Fundamentals', image: '/badges/security-compliance-and-identity-fundamentals-600x600.png' },
  { label: 'MCSE Productivity', image: '/badges/MCSE-Productivity-2018.png' },
  { label: 'MCSE Mobility', image: '/badges/MCSE-Mobility-2019.png' },
  { label: 'MCSE Cloud Platform and Infrastructure', image: '/badges/MCSE-Cloud-Platform-Infrastructure-2018.png' },
  { label: 'MCSA Windows Server 2016', image: '/badges/MCSA-Windows-Server-2016-2018.png' },
  { label: 'MCSA Windows Server 2012', image: '/badges/MCSA-Windows-Server-2012-2018.png' },
  { label: 'MCSA Windows 10', image: '/badges/MCSA-Windows-10-2018.png' },
  { label: 'MCSA Office 365', image: '/badges/MCSA-Office-365-2018.png' },
];

const contactLinks = [
  { label: 'Email', value: 'logan-dinesh@outlook.com', href: 'mailto:logan-dinesh@outlook.com' },
  { label: 'Phone', value: '+49 151 19496953', href: 'tel:+4915119496953' },
  { label: 'LinkedIn', value: 'linkedin.com/in/loganathan-dinesh', href: 'https://www.linkedin.com/in/loganathan-dinesh' },
  { label: 'GitHub', value: 'github.com/dineshlog', href: 'https://github.com/dineshlog' },
  { label: 'Credly', value: 'credly.com/users/loganathan-dinesh', href: 'https://credly.com/users/loganathan-dinesh/badges' },
];

const currentYear = new Date().getFullYear();
---

<Layout>
  <!-- ── Navigation ── -->
  <header class="top-nav">
    <div class="container-shell top-nav-inner">
      <a href="#top" class="brand-mark">
        <span class="brand-badge">DL</span>
        <span class="brand-text">
          <strong>Dinesh Loganathan</strong>
          <small>Information Security &amp; M365 Architect</small>
        </span>
      </a>

      <button id="menu-toggle" class="menu-toggle" aria-expanded="false" aria-controls="primary-nav">
        <span></span><span></span><span></span>
      </button>

      <nav id="primary-nav" class="primary-nav">
        {navLinks.map((link) => (
          <a href={`#${link.id}`}>{link.label}</a>
        ))}
        <a href="/Dinesh_Loganathan_Resume.pdf" download class="nav-cta">Resume ↓</a>
      </nav>
    </div>
  </header>

  <main id="top">

    <!-- ── Hero ── -->
    <section class="hero-section">
      <div class="hero-bg" aria-hidden="true">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
      </div>

      <div class="container-shell hero-inner">
        <div class="hero-content">
          <span class="eyebrow hero-anim" style="animation-delay:0.05s">Portfolio 2026</span>

          <h1 class="hero-h1">
            <span class="h1-line hero-anim" style="animation-delay:0.18s">Building secure,</span>
            <span class="h1-line hero-anim" style="animation-delay:0.32s">scalable digital</span>
            <span class="h1-line h1-accent hero-anim" style="animation-delay:0.46s"><em>workplace systems.</em></span>
          </h1>

          <p class="hero-desc hero-anim" style="animation-delay:0.62s">
            I help organizations modernize Microsoft ecosystems while raising security posture,
            improving operational clarity, and reducing unnecessary tooling overhead.
            My work combines architecture depth, delivery ownership, and clear communication.
          </p>

          <div class="hero-actions hero-anim" style="animation-delay:0.76s">
            <a href="#projects" class="action-primary">View Selected Programs</a>
            <a href="#contact" class="action-secondary">Start a Conversation</a>
          </div>

          <div class="hero-tags hero-anim" style="animation-delay:0.9s" aria-label="Key expertise">
            <span class="pill">Microsoft 365</span>
            <span class="pill">Intune</span>
            <span class="pill">Defender XDR</span>
            <span class="pill">Zero Trust</span>
            <span class="pill">PowerShell</span>
            <span class="pill">Cloud Security</span>
          </div>
        </div>

        <aside class="profile-card hero-anim" style="animation-delay:0.3s">
          <div class="profile-photo-wrap">
            <img src="/ProfilePicture.jpg" alt="Portrait of Dinesh Loganathan" />
          </div>
          <div class="profile-info">
            <p class="profile-location">Based in Cottbus, Germany</p>
            <h2 class="profile-name">Dinesh Loganathan</h2>
            <p class="profile-degree">BEng (Hons) – Computer Network &amp; Cloud Security</p>
          </div>
          <dl class="profile-dl">
            <div>
              <dt>Current focus</dt>
              <dd>Information Security Coordination, M365 Architecture &amp; Governance</dd>
            </div>
            <div>
              <dt>Work style</dt>
              <dd>Consultative, outcome-driven, and security-by-design</dd>
            </div>
            <div>
              <dt>Availability</dt>
              <dd>Open to consulting and full-time opportunities (remote / hybrid)</dd>
            </div>
          </dl>
        </aside>
      </div>

      <div class="hero-scroll-hint" aria-hidden="true">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ── Profile / Metrics ── -->
    <section id="profile" class="section-block metrics-section">
      <div class="container-shell">
        <div class="metrics-head reveal">
          <span class="eyebrow">Profile Snapshot</span>
          <h2 class="section-title">Impact-oriented delivery, not just platform administration</h2>
          <p class="section-copy">
            Across MSP, enterprise, and consulting environments, I have delivered complex Microsoft and security
            programs with a focus on risk reduction, reliability, and measurable business outcomes.
          </p>
        </div>

        <div class="metric-grid">
          {keyMetrics.map((metric, i) => (
            <article class="metric-card reveal" style={`transition-delay:${i * 0.1}s`}>
              <p class="metric-value">{metric.value}</p>
              <p class="metric-label">{metric.label}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Expertise ── -->
    <section id="expertise" class="section-block expertise-section">
      <div class="container-shell">
        <div class="reveal">
          <span class="eyebrow">Expertise</span>
          <h2 class="section-title">Structured capability across platform, security, and operations</h2>
        </div>

        <div class="expertise-grid">
          {expertiseAreas.map((area, i) => (
            <article class="expertise-card reveal" style={`transition-delay:${i * 0.1}s`}>
              <div class="expertise-card-top">
                <span class="expertise-num">0{i + 1}</span>
                <h3>{area.title}</h3>
              </div>
              <p>{area.summary}</p>
              <ul>
                {area.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Experience ── -->
    <section id="experience" class="section-block experience-section">
      <div class="container-shell">
        <div class="reveal">
          <span class="eyebrow">Experience</span>
          <h2 class="section-title">Career progression across enterprise and managed services</h2>
        </div>

        <div class="timeline">
          {timeline.map((item, i) => (
            <article class="timeline-item reveal" style={`transition-delay:${i * 0.08}s`}>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-body">
                <p class="timeline-period">{item.period}</p>
                <h3 class="timeline-title">{item.title}</h3>
                <p class="timeline-company">{item.company}</p>
                <p class="timeline-detail">{item.detail}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Projects ── -->
    <section id="projects" class="section-block projects-section">
      <div class="container-shell">
        <div class="reveal">
          <span class="eyebrow">Selected Programs</span>
          <h2 class="section-title">Programs delivered from architecture to implementation</h2>
        </div>

        <div class="project-grid">
          {projects.map((project, i) => (
            <article class="project-card reveal" style={`transition-delay:${i * 0.08}s`}>
              <div class="project-card-inner">
                <h3>{project.name}</h3>
                <p>{project.result}</p>
                <div class="project-stack">{project.stack}</div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Credentials ── -->
    <section id="credentials" class="section-block credentials-section">
      <div class="container-shell">
        <div class="reveal">
          <span class="eyebrow">Credentials</span>
          <h2 class="section-title">Microsoft certification track with security and cloud depth</h2>
          <p class="section-copy">
            Additional active and transcript-backed credentials available through Microsoft Learn and Credly.
          </p>
        </div>

        <div class="cred-links reveal">
          <a href="https://learn.microsoft.com/en-us/users/logan-dinesh/transcript" target="_blank" rel="noopener noreferrer" class="cred-link-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Microsoft Learn Transcript
          </a>
          <a href="https://credly.com/users/loganathan-dinesh/badges" target="_blank" rel="noopener noreferrer" class="cred-link-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            Credly Badge Profile
          </a>
        </div>

        <div class="badge-grid">
          {certifications.map((cert, i) => (
            <article class="badge-card reveal" style={`transition-delay:${i * 0.07}s`}>
              <div class="badge-img-wrap">
                <img src={cert.image} alt={cert.label} loading="lazy" />
              </div>
              <p class="badge-label">{cert.label}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Contact ── -->
    <section id="contact" class="section-block contact-section">
      <div class="container-shell contact-grid">
        <div class="contact-left reveal">
          <span class="eyebrow">Contact</span>
          <h2 class="section-title">Open for collaboration and security-first modernization projects</h2>
          <p class="section-copy">
            Available for consulting engagements and full-time opportunities focused on Microsoft 365,
            information security, endpoint strategy, and cloud operations.
          </p>
          <div class="hero-actions" style="margin-top:32px">
            <a href="/Dinesh_Loganathan_Resume.pdf" download class="action-primary">Download Resume</a>
            <a href="mailto:logan-dinesh@outlook.com" class="action-secondary">Email Directly</a>
          </div>
        </div>

        <div class="contact-right reveal" style="transition-delay:0.1s">
          {contactLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : '_self'}
              rel="noopener noreferrer"
              class="contact-item"
            >
              <span class="contact-label">{link.label}</span>
              <span class="contact-value">{link.value}</span>
              <span class="contact-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container-shell footer-inner">
      <p>© {currentYear} Dinesh Loganathan</p>
      <p>Built with Astro · Deployed on GitHub Pages</p>
    </div>
  </footer>

  <!-- ── Mobile nav toggle ── -->
  <script is:inline>
    (function () {
      var toggle = document.getElementById('menu-toggle');
      var nav = document.getElementById('primary-nav');
      if (!toggle || !nav) return;
      toggle.addEventListener('click', function () {
        var open = nav.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
        toggle.classList.toggle('is-open', open);
      });
      nav.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
          nav.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.classList.remove('is-open');
        });
      });
    })();
  </script>

  <style>
    /* ─── Keyframes ─── */
    @keyframes hero-in {
      from { opacity: 0; transform: translateY(32px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes drift1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50%       { transform: translate(-50px, 70px) scale(1.08); }
    }

    @keyframes drift2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50%       { transform: translate(70px, -50px) scale(0.94); }
    }

    @keyframes drift3 {
      0%, 100% { transform: translate(-50%, -50%) scale(1); }
      50%       { transform: translate(-50%, -50%) scale(1.35); }
    }

    @keyframes scroll-pulse {
      0%, 100% { transform: scaleY(1); opacity: 0.5; }
      50%       { transform: scaleY(0.4); opacity: 1; }
    }

    /* ─── NAV ─── */
    .top-nav {
      position: sticky;
      top: 0;
      z-index: 60;
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      background: rgba(8, 12, 24, 0.82);
      border-bottom: 1px solid rgba(201, 169, 110, 0.08);
    }

    .top-nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 72px;
    }

    .brand-mark {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .brand-badge {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(201,169,110,0.2), rgba(201,169,110,0.08));
      border: 1px solid rgba(201, 169, 110, 0.25);
      color: var(--brand);
      font-weight: 700;
      font-size: 0.88rem;
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }

    .brand-text strong {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.1;
    }

    .brand-text small {
      display: block;
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.02em;
      margin-top: 2px;
    }

    .primary-nav {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .primary-nav a {
      text-decoration: none;
      color: var(--muted);
      font-weight: 500;
      font-size: 0.84rem;
      padding: 7px 12px;
      border-radius: 8px;
      letter-spacing: 0.01em;
      transition: color 0.2s, background 0.2s;
    }

    .primary-nav a:hover {
      color: var(--brand);
      background: rgba(201, 169, 110, 0.07);
    }

    .nav-cta {
      background: rgba(201, 169, 110, 0.1) !important;
      border: 1px solid rgba(201, 169, 110, 0.25) !important;
      color: var(--brand) !important;
      font-weight: 600 !important;
      margin-left: 6px;
      letter-spacing: 0.03em !important;
    }

    .nav-cta:hover {
      background: rgba(201, 169, 110, 0.18) !important;
      border-color: rgba(201, 169, 110, 0.45) !important;
    }

    .menu-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 9px 10px;
      cursor: pointer;
    }

    .menu-toggle span {
      display: block;
      width: 18px;
      height: 1.5px;
      background: var(--muted);
      border-radius: 1px;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    .menu-toggle.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .menu-toggle.is-open span:nth-child(2) { opacity: 0; }
    .menu-toggle.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    /* ─── HERO ─── */
    .hero-section {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      overflow: hidden;
      padding: 140px 0 100px;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(201, 169, 110, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(201, 169, 110, 0.025) 1px, transparent 1px);
      background-size: 72px 72px;
    }

    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      pointer-events: none;
    }

    .orb-1 {
      width: 800px;
      height: 800px;
      background: radial-gradient(circle at center, rgba(201, 169, 110, 0.13), transparent 65%);
      top: -300px;
      right: -200px;
      animation: drift1 14s ease-in-out infinite;
    }

    .orb-2 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle at center, rgba(77, 155, 191, 0.1), transparent 65%);
      bottom: -200px;
      left: -150px;
      animation: drift2 18s ease-in-out infinite;
    }

    .orb-3 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle at center, rgba(201, 169, 110, 0.07), transparent 65%);
      top: 50%;
      left: 38%;
      animation: drift3 11s ease-in-out infinite;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1.25fr 0.9fr;
      gap: 64px;
      align-items: center;
    }

    .hero-anim {
      opacity: 0;
      animation: hero-in 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .hero-h1 {
      margin: 20px 0 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 6.5vw, 5.8rem);
      font-weight: 600;
      line-height: 1.03;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .h1-line {
      display: block;
    }

    .h1-accent {
      color: var(--brand);
    }

    .h1-accent em {
      font-style: italic;
    }

    .hero-desc {
      margin: 24px 0 0;
      max-width: 54ch;
      color: var(--muted);
      font-size: 1.04rem;
      line-height: 1.8;
      font-weight: 400;
    }

    .hero-actions {
      margin-top: 34px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .action-primary,
    .action-secondary {
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      border-radius: 999px;
      padding: 13px 26px;
      font-weight: 600;
      font-size: 0.88rem;
      letter-spacing: 0.03em;
      transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease, border-color 0.22s ease;
    }

    .action-primary {
      background: var(--brand);
      color: #080c18;
      border: 1px solid var(--brand);
    }

    .action-primary:hover {
      transform: translateY(-2px);
