      padding: clamp(12px,1.4dvh,16px);
      display: flex;
      flex-direction: column;
      gap: 6px;
      overflow: hidden;
      position: relative;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .project-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--brand), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .project-card:hover { border-color: rgba(201,169,110,0.22); box-shadow: var(--glow-hover); transform: translateY(-3px); }
    .project-card:hover::before { opacity: 1; }

    .project-card h3 {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.9rem,1.2vw,1.05rem);
      font-weight: 600;
      line-height: 1.25;
      color: var(--text);
      flex-shrink: 0;
    }

    .project-card p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.7rem,0.9vw,0.8rem);
      line-height: 1.55;
      flex: 1;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
    }

    .project-stack {
      font-size: clamp(0.62rem,0.8vw,0.7rem);
      color: var(--brand);
      font-weight: 600;
      letter-spacing: 0.02em;
      flex-shrink: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ═══════════════════════════════════════════
       WALLET TABS
    ═══════════════════════════════════════════ */
    .wallet-tabbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: clamp(10px,1.4dvh,16px);
      flex-shrink: 0;
    }

    .wallet-tabs {
      display: flex;
      gap: 4px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 4px;
    }

    .wallet-tab {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 8px 16px;
      border-radius: 9px;
      border: none;
      background: transparent;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(0.75rem,1vw,0.84rem);
      font-weight: 600;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: color 0.25s, background 0.25s, box-shadow 0.25s;
      position: relative;
