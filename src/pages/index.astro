  <!-- ── Scripts ── -->
  <script is:inline>
  (function () {
    var scroll = document.getElementById('page-scroll');
    var panels = Array.from(document.querySelectorAll('.snap-panel'));
    var dots   = Array.from(document.querySelectorAll('.scroll-dot'));
    var toggle = document.getElementById('menu-toggle');
    var nav    = document.getElementById('primary-nav');

    /* ── Scroll to panel by id ── */
    function scrollTo(id) {
      var el = document.getElementById(id);
      if (el && scroll) {
        scroll.scrollTo({ top: el.offsetTop, behavior: 'smooth' });
      }
    }

    /* ── Nav link clicks ── */
    document.querySelectorAll('[data-scroll]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        var id = el.getAttribute('data-scroll');
        if (id) {
          e.preventDefault();
          scrollTo(id);
          if (nav) { nav.classList.remove('is-open'); toggle && toggle.classList.remove('is-open'); }
        }
      });
    });

    /* ── Scroll dot clicks ── */
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        scrollTo(dot.getAttribute('data-target'));
      });
    });

    /* ── Active dot tracking via IntersectionObserver on scroll container ── */
    if ('IntersectionObserver' in window && scroll) {
      var dotObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var pid = entry.target.getAttribute('data-panel');
            dots.forEach(function (d) {
              d.classList.toggle('active', d.getAttribute('data-target') === pid);
            });
          }
        });
      }, { root: scroll, threshold: 0.5 });
      panels.forEach(function (p) { dotObs.observe(p); });
    }

    /* ── Reveal animations via IntersectionObserver on scroll container ── */
    var revealEls = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && scroll) {
      var revObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            revObs.unobserve(entry.target);
          }
        });
      }, { root: scroll, threshold: 0.08 });
      revealEls.forEach(function (el) { revObs.observe(el); });
    } else {
      revealEls.forEach(function (el) { el.classList.add('in-view'); });
    }

    /* ── Mobile menu toggle ── */
    if (toggle && nav) {
      toggle.addEventListener('click', function () {
        var open = nav.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
        toggle.classList.toggle('is-open', open);
      });
    }

    /* ── Set first dot active ── */
    if (dots[0]) dots[0].classList.add('active');

    /* ── Wallet tab switching ── */
    document.querySelectorAll('.wallet-tab').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-wallet');

        /* update tab buttons */
        document.querySelectorAll('.wallet-tab').forEach(function (t) {
          var isActive = t.getAttribute('data-wallet') === target;
          t.classList.toggle('active', isActive);
          t.setAttribute('aria-selected', String(isActive));
        });

        /* update panes */
        document.querySelectorAll('.wallet-pane').forEach(function (pane) {
          var show = pane.id === 'wallet-' + target;
          pane.classList.toggle('active', show);
          pane.setAttribute('aria-hidden', String(!show));
        });
      });
    });

    /* ── Solution tab switching ── */
    document.querySelectorAll('.sol-tab').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-sol');
        document.querySelectorAll('.sol-tab').forEach(function (t) {
          var isActive = t.getAttribute('data-sol') === target;
          t.classList.toggle('active', isActive);
          t.setAttribute('aria-selected', String(isActive));
        });
        document.querySelectorAll('.sol-pane').forEach(function (pane) {
          var show = pane.id === 'sol-pane-' + target;
          pane.classList.toggle('active', show);
          pane.setAttribute('aria-hidden', String(!show));
        });
      });
    });

    /* ── Skill Matrix hover interactions ── */
    (function () {
      var svg = document.querySelector('.matrix-svg');
      if (!svg) return;
      var certs   = Array.from(svg.querySelectorAll('.m-cert'));
      var domains = Array.from(svg.querySelectorAll('.m-domain'));
      var conns   = Array.from(svg.querySelectorAll('.m-conn'));

      function clearHover() {
        certs.forEach(function (el) { el.classList.remove('m-highlight', 'm-dim'); });
        domains.forEach(function (el) { el.classList.remove('m-highlight', 'm-dim'); });
        conns.forEach(function (el) { el.classList.remove('m-highlight', 'm-dim'); });
      }

      certs.forEach(function (cert) {
        var certId = cert.getAttribute('data-cert');
        cert.addEventListener('mouseenter', function () {
          clearHover();
          cert.classList.add('m-highlight');
          var connectedDoms = new Set();
          conns.forEach(function (conn) {
            if (conn.getAttribute('data-cert') === certId) {
              conn.classList.add('m-highlight');
              connectedDoms.add(conn.getAttribute('data-dom'));
            } else {
              conn.classList.add('m-dim');
            }
          });
          domains.forEach(function (d) {
            if (connectedDoms.has(d.getAttribute('data-dom'))) {
              d.classList.add('m-highlight');
            } else {
              d.classList.add('m-dim');
            }
          });
          certs.forEach(function (c) { if (c !== cert) c.classList.add('m-dim'); });
        });
        cert.addEventListener('mouseleave', clearHover);
      });

      domains.forEach(function (dom) {
        var domId = dom.getAttribute('data-dom');
        dom.addEventListener('mouseenter', function () {
          clearHover();
          dom.classList.add('m-highlight');
          var connectedCerts = new Set();
          conns.forEach(function (conn) {
            if (conn.getAttribute('data-dom') === domId) {
              conn.classList.add('m-highlight');
              connectedCerts.add(conn.getAttribute('data-cert'));
            } else {
              conn.classList.add('m-dim');
            }
          });
          certs.forEach(function (c) {
            if (connectedCerts.has(c.getAttribute('data-cert'))) {
              c.classList.add('m-highlight');
            } else {
              c.classList.add('m-dim');
            }
          });
          domains.forEach(function (d) { if (d !== dom) d.classList.add('m-dim'); });
        });
        dom.addEventListener('mouseleave', clearHover);
      });
    })();

    /* ── Testimonials auto-carousel ── */
    (function () {
      var slides  = Array.from(document.querySelectorAll('.testim-slide'));
      var dots    = Array.from(document.querySelectorAll('.testim-dot'));
      var prevBtn = document.getElementById('testim-prev');
      var nextBtn = document.getElementById('testim-next');
      if (!slides.length) return;
      var current = 0;
      var timer;

      function goTo(idx) {
        slides[current].classList.remove('active');
        if (dots[current]) dots[current].classList.remove('active');
        current = ((idx % slides.length) + slides.length) % slides.length;
        slides[current].classList.add('active');
        if (dots[current]) dots[current].classList.add('active');
      }

      function startTimer() {
        clearInterval(timer);
        timer = setInterval(function () { goTo(current + 1); }, 5000);
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          goTo(parseInt(dot.getAttribute('data-slide'), 10));
          startTimer();
        });
      });

      if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); startTimer(); });
      if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); startTimer(); });

      startTimer();
    })();
  })();
  </script>

  <style>
    /* ═══════════════════════════════════════════
       KEYFRAMES
    ═══════════════════════════════════════════ */
    @keyframes hero-in {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes drift1 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%     { transform: translate(-50px,70px) scale(1.08); }
    }
    @keyframes drift2 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%     { transform: translate(70px,-50px) scale(0.94); }
    }
    @keyframes drift3 {
      0%,100% { transform: translate(-50%,-50%) scale(1); }
      50%     { transform: translate(-50%,-50%) scale(1.35); }
    }
    @keyframes pulse-line {
      0%,100% { transform: scaleY(1); opacity:0.4; }
      50%     { transform: scaleY(0.35); opacity:1; }
    }

    /* ═══════════════════════════════════════════
       SNAP CONTAINER
    ═══════════════════════════════════════════ */
    .page-scroll {
      height: 100dvh;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .page-scroll::-webkit-scrollbar { display: none; }

    /* ═══════════════════════════════════════════
       SNAP PANELS — base
    ═══════════════════════════════════════════ */
    .snap-panel {
      height: 100dvh;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
      /* top pad = nav height (86px) + breathing space */
      padding: clamp(96px,9dvh,120px) 0 clamp(20px,2.5dvh,34px);
    }

    .tint-panel {
      background: linear-gradient(180deg,
        rgba(201,169,110,0.02) 0%,
        rgba(201,169,110,0.04) 40%,
        rgba(201,169,110,0.02) 100%);
      border-top: 1px solid var(--line-subtle);
      border-bottom: 1px solid var(--line-subtle);
    }

    /* Panel shell — flex column, fills snap-panel interior */
    .panel-shell {
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .panel-head {
      flex-shrink: 0;
      margin-bottom: clamp(10px,1.5dvh,18px);
    }

    /* ═══════════════════════════════════════════
       FIXED NAV
    ═══════════════════════════════════════════ */
    .top-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 200;
      height: 86px;
      backdrop-filter: blur(18px) saturate(180%);
      -webkit-backdrop-filter: blur(18px) saturate(180%);
      background: rgba(8,12,24,0.85);
      border-bottom: 1px solid rgba(201,169,110,0.08);
    }

    .top-nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      height: 86px;
    }

    .brand-mark {
      display: inline-flex;
      align-items: center;
      gap: 11px;
      text-decoration: none;
      cursor: pointer;
    }

    .brand-badge {
      width: 43px;
      height: 43px;
      border-radius: 11px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(201,169,110,0.2), rgba(201,169,110,0.07));
      border: 1px solid rgba(201,169,110,0.25);
      color: var(--brand);
      font-weight: 700;
      font-size: 0.84rem;
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }

    .brand-text strong {
      display: block;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.1;
    }

    .brand-text small {
      display: block;
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.02em;
      margin-top: 2px;
    }

    .primary-nav {
      display: flex;
      align-items: center;
      gap: 3px;
    }

    .primary-nav a {
      text-decoration: none;
      color: var(--muted);
      font-weight: 500;
      font-size: 0.82rem;
      padding: 6px 11px;
      border-radius: 7px;
      letter-spacing: 0.01em;
      transition: color 0.2s, background 0.2s;
      cursor: pointer;
    }

    .primary-nav a:hover {
      color: var(--brand);
      background: rgba(201,169,110,0.07);
    }

    .nav-cta {
      background: rgba(201,169,110,0.1) !important;
      border: 1px solid rgba(201,169,110,0.22) !important;
      color: var(--brand) !important;
      font-weight: 600 !important;
      margin-left: 6px;
      letter-spacing: 0.03em !important;
    }

    .nav-cta:hover {
      background: rgba(201,169,110,0.18) !important;
      border-color: rgba(201,169,110,0.42) !important;
    }

    .menu-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 1px solid var(--line);
      border-radius: 7px;
      padding: 8px 10px;
      cursor: pointer;
    }

    .menu-toggle span {
      display: block;
      width: 18px;
      height: 1.5px;
      background: var(--muted);
      border-radius: 1px;
      transition: transform 0.25s, opacity 0.25s;
    }

    .menu-toggle.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .menu-toggle.is-open span:nth-child(2) { opacity: 0; }
    .menu-toggle.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    /* ═══════════════════════════════════════════
       SCROLL DOTS
    ═══════════════════════════════════════════ */
    .scroll-dots {
      position: fixed;
      right: 24px;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 11px;
      z-index: 150;
    }

    .scroll-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(201,169,110,0.2);
      border: 1px solid rgba(201,169,110,0.25);
      cursor: pointer;
      padding: 0;
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }

    .scroll-dot.active {
      background: var(--brand);
      border-color: var(--brand);
      box-shadow: 0 0 10px rgba(201,169,110,0.45);
      transform: scale(1.5);
    }

    .scroll-dot:hover:not(.active) {
      background: rgba(201,169,110,0.4);
      transform: scale(1.25);
    }

    /* ═══════════════════════════════════════════
       HERO PANEL
    ═══════════════════════════════════════════ */
    .hero-panel {
      padding-top: 86px; /* exact nav height — hero is centered differently */
      justify-content: center;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(201,169,110,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(201,169,110,0.025) 1px, transparent 1px);
      background-size: 72px 72px;
    }

    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      pointer-events: none;
    }

    .orb-1 {
      width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(201,169,110,0.13), transparent 65%);
      top: -280px; right: -180px;
      animation: drift1 14s ease-in-out infinite;
    }

    .orb-2 {
      width: 550px; height: 550px;
      background: radial-gradient(circle, rgba(77,155,191,0.1), transparent 65%);
      bottom: -180px; left: -130px;
      animation: drift2 18s ease-in-out infinite;
    }

    .orb-3 {
      width: 380px; height: 380px;
      background: radial-gradient(circle, rgba(201,169,110,0.07), transparent 65%);
      top: 50%; left: 38%;
      animation: drift3 11s ease-in-out infinite;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1.3fr 0.85fr;
      gap: clamp(32px,4vw,60px);
      align-items: center;
    }

    .hero-anim {
      opacity: 0;
      animation: hero-in 0.9s cubic-bezier(0.16,1,0.3,1) both;
    }

    .hero-h1 {
      margin: clamp(14px,2dvh,20px) 0 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.6rem, 5.5vw, 5.4rem);
      font-weight: 600;
      line-height: 1.04;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .h1-line { display: block; }
    .h1-accent { color: var(--brand); }
    .h1-accent em { font-style: italic; }

    .hero-desc {
      margin: clamp(14px,2dvh,20px) 0 0;
      max-width: 50ch;
      color: var(--muted);
      font-size: clamp(0.88rem,1.2vw,1rem);
      line-height: 1.75;
    }

    .hero-actions {
      margin-top: clamp(16px,2dvh,28px);
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .action-primary, .action-secondary {
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      border-radius: 999px;
      padding: clamp(10px,1.3dvh,13px) clamp(18px,2vw,24px);
      font-weight: 600;
      font-size: clamp(0.8rem,1vw,0.88rem);
      letter-spacing: 0.03em;
      transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
      cursor: pointer;
    }

    .action-primary {
      background: var(--brand);
      color: #080c18;
      border: 1px solid var(--brand);
    }

    .action-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(201,169,110,0.35);
      background: var(--brand-strong);
    }

    .action-secondary {
      background: transparent;
      color: var(--brand);
      border: 1px solid rgba(201,169,110,0.28);
    }

    .action-secondary:hover {
      transform: translateY(-2px);
      background: rgba(201,169,110,0.08);
      border-color: rgba(201,169,110,0.5);
    }

    .hero-tags {
      margin-top: clamp(14px,1.8dvh,22px);
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }

    /* Profile card */
    .profile-card {
      background: var(--surface);
      border: 1px solid rgba(201,169,110,0.14);
      border-radius: 18px;
      padding: clamp(14px,1.8dvh,20px);
      box-shadow: var(--shadow), var(--shadow-gold);
      display: flex;
      flex-direction: column;
      gap: clamp(10px,1.5dvh,16px);
      max-height: calc(100dvh - 100px);
      overflow: hidden;
    }

    .profile-photo-wrap {
      border-radius: 11px;
      overflow: hidden;
      background: linear-gradient(135deg, rgba(201,169,110,0.08), rgba(8,12,24,0.3));
      flex-shrink: 0;
    }

    .profile-card img {
      width: 100%;
      height: clamp(160px,22dvh,250px);
      object-fit: contain;
      object-position: center top;
      border-radius: 11px;
      display: block;
    }

    .profile-location {
      margin: 0;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-weight: 600;
      color: var(--brand);
    }

    .profile-name {
      margin: 3px 0 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.3rem,2vw,1.55rem);
      font-weight: 600;
      line-height: 1.15;
      color: var(--text);
    }

    .profile-degree {
      margin: 2px 0 0;
      color: var(--muted);
      font-size: clamp(0.76rem,1vw,0.84rem);
      line-height: 1.4;
    }

    .profile-dl {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
      border-top: 1px solid var(--line-subtle);
      padding-top: clamp(10px,1.2dvh,14px);
    }

    .profile-dl dt {
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--brand);
      font-weight: 600;
      margin-bottom: 2px;
    }

    .profile-dl dd {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.78rem,1vw,0.85rem);
      line-height: 1.45;
    }

    .scroll-hint {
      position: absolute;
      bottom: clamp(14px,2dvh,24px);
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 7px;
      color: var(--muted);
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      opacity: 0.4;
      z-index: 1;
    }

    .scroll-line {
      width: 1px;
      height: 30px;
      background: var(--brand);
      transform-origin: top;
      animation: pulse-line 2s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════════
       METRIC GRID
    ═══════════════════════════════════════════ */
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(8px,1dvh,12px);
      flex-shrink: 0;
      margin-bottom: clamp(10px,1.4dvh,16px);
    }

    .metric-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: clamp(10px,1.4dvh,16px) clamp(12px,1.2vw,18px);
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .metric-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--brand), transparent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .metric-card:hover { border-color: rgba(201,169,110,0.24); box-shadow: var(--glow-hover); transform: translateY(-3px); }
    .metric-card:hover::before { opacity: 1; }

    .metric-value {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.5rem,2.5dvh,2.2rem);
      font-weight: 600;
      color: var(--brand);
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .metric-label {
      margin: clamp(3px,0.45dvh,6px) 0 0;
      color: var(--muted);
      font-size: clamp(0.66rem,0.88vw,0.76rem);
      line-height: 1.45;
    }

    /* ═══════════════════════════════════════════
       SKILL MATRIX
    ═══════════════════════════════════════════ */
    .matrix-outer {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: clamp(6px,0.9dvh,12px);
    }

    .matrix-svg-wrap {
      flex: 1;
      min-height: 0;
      display: flex;
      align-items: stretch;
    }

    .matrix-svg {
      width: 100%;
      height: 100%;
    }

    .m-cert, .m-domain {
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .m-cert circle {
      transition: stroke 0.2s, stroke-width 0.2s, filter 0.2s;
    }

    .m-cert:hover > circle,
    .m-cert.m-highlight > circle {
      stroke: var(--brand);
      stroke-width: 2.5;
      filter: drop-shadow(0 0 6px rgba(201,169,110,0.5));
    }

    .m-cert.m-dim, .m-domain.m-dim { opacity: 0.12; }

    .m-conn { transition: stroke-opacity 0.2s, stroke-width 0.2s; }
    .m-conn.m-dim { stroke-opacity: 0.04 !important; }
    .m-conn.m-highlight { stroke-opacity: 0.85 !important; stroke-width: 2.5 !important; }

    .m-domain rect { transition: filter 0.2s, stroke-opacity 0.2s; }
    .m-domain.m-highlight rect { stroke-opacity: 0.9; }

    .matrix-legend {
      flex-shrink: 0;
      display: flex;
      gap: clamp(10px,2vw,28px);
      justify-content: center;
      flex-wrap: wrap;
    }

    .matrix-legend-item {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: clamp(0.66rem,0.88vw,0.74rem);
      font-weight: 500;
      color: var(--muted);
    }

    .matrix-legend-swatch {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
      opacity: 0.75;
    }

    /* ═══════════════════════════════════════════
       TESTIMONIALS
    ═══════════════════════════════════════════ */
    .testimonials-block {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: clamp(7px,0.9dvh,11px);
    }

    .testim-head { flex-shrink: 0; }

    .testim-tagline {
      margin: 2px 0 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.92rem,1.2vw,1.1rem);
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
    }

    .testim-stage {
      flex: 1;
      min-height: 0;
      position: relative;
      border-radius: 13px;
      overflow: hidden;
      background: var(--surface);
      border: 1px solid var(--line);
    }

    .testim-slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .testim-slide.active { opacity: 1; }

    .testim-slide img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center top;
      display: block;
    }

    .testim-placeholder {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 20px;
      text-align: center;
      width: 100%;
      height: 100%;
    }

    .testim-placeholder p {
      margin: 0;
      font-size: clamp(0.78rem,1vw,0.88rem);
      font-weight: 500;
      color: var(--muted-lt);
    }

    .testim-placeholder small {
      font-size: 0.66rem;
      color: var(--muted);
      opacity: 0.5;
      line-height: 1.5;
    }

    .testim-controls {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .testim-dots { display: flex; align-items: center; gap: 6px; }

    .testim-dot {
      width: 6px;
      height: 6px;
      border-radius: 3px;
      border: 1px solid rgba(201,169,110,0.3);
      background: transparent;
      cursor: pointer;
      padding: 0;
      transition: all 0.28s cubic-bezier(0.34,1.56,0.64,1);
    }

    .testim-dot.active {
      width: 18px;
      background: var(--brand);
      border-color: var(--brand);
    }

    .testim-nav { display: flex; gap: 6px; }

    .testim-btn {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1px solid var(--line);
      background: var(--surface);
      color: var(--muted);
      cursor: pointer;
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s;
    }

    .testim-btn:hover {
      color: var(--brand);
      border-color: rgba(201,169,110,0.38);
      background: rgba(201,169,110,0.06);
      transform: scale(1.1);
    }

    /* ═══════════════════════════════════════════
       EXPERTISE GRID
    ═══════════════════════════════════════════ */
    .expertise-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, 1fr);
      gap: clamp(10px,1.2dvh,14px);
      flex: 1;
      min-height: 0;
    }

    .expertise-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: clamp(14px,1.8dvh,22px);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }

    .expertise-card:hover { border-color: rgba(201,169,110,0.2); box-shadow: var(--glow-hover); transform: translateY(-2px); }

    .expertise-top {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: clamp(8px,1dvh,14px);
      flex-shrink: 0;
    }

    .expertise-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.8rem,3dvh,2.4rem);
      font-weight: 400;
      color: rgba(201,169,110,0.18);
      line-height: 1;
      flex-shrink: 0;
      margin-top: -3px;
    }

    .expertise-card h3 {
      margin: 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1rem,1.6vw,1.25rem);
      font-weight: 600;
      line-height: 1.25;
      color: var(--text);
    }

    .expertise-card > p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.78rem,1vw,0.88rem);
      line-height: 1.6;
      flex-shrink: 0;
    }

    .expertise-card ul {
      margin: clamp(8px,1dvh,12px) 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 6px;
      border-top: 1px solid var(--line-subtle);
      padding-top: clamp(8px,1dvh,12px);
      flex: 1;
      overflow: hidden;
    }

    .expertise-card li {
      position: relative;
      padding-left: 14px;
      color: var(--muted-lt);
      font-size: clamp(0.74rem,0.95vw,0.84rem);
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .expertise-card li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.48rem;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--brand);
      opacity: 0.55;
    }

    /* ═══════════════════════════════════════════
       TIMELINE
    ═══════════════════════════════════════════ */
    .timeline {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: clamp(6px,0.8dvh,10px);
      padding-left: 26px;
      position: relative;
      overflow: hidden;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 6px;
      top: 8px; bottom: 8px;
      width: 1px;
      background: linear-gradient(to bottom, var(--brand), rgba(201,169,110,0.08));
    }

    .tl-item {
      display: flex;
      gap: 0;
      flex: 1;
      min-height: 0;
      position: relative;
    }

    .tl-dot {
      position: absolute;
      left: -21px;
      top: clamp(12px,1.5dvh,16px);
      width: 11px; height: 11px;
      border-radius: 50%;
      border: 2px solid var(--brand);
      background: var(--bg);
      flex-shrink: 0;
      transition: background 0.3s, box-shadow 0.3s;
    }

    .tl-item:hover .tl-dot {
      background: var(--brand);
      box-shadow: 0 0 12px rgba(201,169,110,0.4);
    }

    .tl-body {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: clamp(10px,1.3dvh,14px) clamp(14px,1.5vw,18px);
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      transition: border-color 0.3s;
    }

    .tl-item:hover .tl-body { border-color: rgba(201,169,110,0.2); }

    .tl-period {
      margin: 0;
      font-size: clamp(0.58rem,0.8vw,0.65rem);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--brand);
      font-weight: 600;
    }

    .tl-title {
      margin: 3px 0 0;
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(0.95rem,1.4vw,1.15rem);
      font-weight: 600;
      line-height: 1.2;
      color: var(--text);
    }

    .tl-company {
      margin: 2px 0 0;
      color: var(--muted-lt);
      font-size: clamp(0.72rem,0.95vw,0.82rem);
      font-weight: 500;
    }

    .tl-detail {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: clamp(0.72rem,0.95vw,0.82rem);
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ═══════════════════════════════════════════
       PROJECT GRID
    ═══════════════════════════════════════════ */
    .project-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: clamp(8px,1dvh,12px);
      flex: 1;
      min-height: 0;
    }

    .project-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
