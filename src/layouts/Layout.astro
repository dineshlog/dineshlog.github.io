---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Dinesh Loganathan | Microsoft 365 Expert & InfoSec Consultant',
  description = 'Security and privacy focused AI solutions and Modern Workspace consultant with 10+ years experience. Microsoft 365 Expert, InfoSec Specialist, Certified Trainer.',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Dinesh Loganathan" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dineshlog.github.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dineshlog.github.io" />
    <meta property="og:image" content="https://dineshlog.github.io/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=()" />
    <meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Figtree:ital,wght@0,300;0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --sidebar-w: 18rem;
        --accent: #3b82f6;
        --accent-dim: rgba(59,130,246,0.15);
        --accent-glow: rgba(59,130,246,0.25);
      }
      * { box-sizing: border-box; }

      /* Nav active state */
      .nav-active {
        color: var(--accent) !important;
        background: var(--accent-dim) !important;
        border-left-color: var(--accent) !important;
      }

      /* Dot-grid sidebar texture (dark mode only) */
      .sidebar-texture {
        background-image: radial-gradient(circle, rgba(59,130,246,0.12) 1px, transparent 1px);
        background-size: 20px 20px;
      }

      /* Section number labels */
      .section-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
      }
      .section-num::before {
        content: '';
        display: inline-block;
        width: 1.5rem;
        height: 1px;
        background: var(--accent);
        opacity: 0.6;
      }

      /* Consistent typography */
      .section-heading {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        line-height: 1.1;
      }
      body { font-family: 'Figtree', sans-serif; }

      /* Scrollbar styling */
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: rgba(59,130,246,0.3); border-radius: 2px; }

      /* Tag chips */
      .chip {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.65rem;
        border-radius: 9999px;
        font-size: 0.72rem;
        font-weight: 500;
        font-family: 'JetBrains Mono', monospace;
        border: 1px solid;
        white-space: nowrap;
      }

      /* Card hover lift */
      .card-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
      }
      .card-lift:hover {
        transform: translateY(-2px);
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-[#0a0f1e] text-slate-800 dark:text-slate-200 antialiased">
    <slot />
  </body>
</html>
