---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dinesh Loganathan | Information Security & Microsoft 365 Architect',
  description = 'Information Security Coordinator and Microsoft 365 Architect with 10+ years delivering secure workplace transformation across EMEA and APAC.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Dinesh Loganathan" />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0d1b2a" />

    <link rel="canonical" href="https://dineshlog.github.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dineshlog.github.io" />
    <meta property="og:image" content="https://dineshlog.github.io/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Fraunces:opsz,wght,SOFT@9..144,500..700,100&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <style is:global>
      :root {
        --bg: #f6f7f3;
        --surface: #ffffff;
        --surface-alt: #eef2ec;
        --text: #16212e;
        --muted: #4b5c6a;
        --line: #d5dcd2;
        --brand: #1f6f78;
        --brand-strong: #10484f;
        --accent: #d97745;
        --radius-lg: 24px;
        --radius-md: 16px;
        --shadow-soft: 0 18px 45px rgba(17, 31, 45, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Manrope', sans-serif;
        background:
          radial-gradient(circle at 12% 15%, rgba(31, 111, 120, 0.12), transparent 36%),
          radial-gradient(circle at 85% 8%, rgba(217, 119, 69, 0.11), transparent 35%),
          var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
      }

      a {
        color: inherit;
      }

      .container-shell {
        width: min(1120px, 92vw);
        margin: 0 auto;
      }

      .section-block {
        padding: 84px 0;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-weight: 700;
        color: var(--brand-strong);
      }

      .eyebrow::before {
        content: '';
        width: 32px;
        height: 1px;
        background: rgba(16, 72, 79, 0.35);
      }

      .section-title {
        margin: 14px 0 14px;
        font-family: 'Fraunces', serif;
        font-weight: 600;
        letter-spacing: -0.01em;
        font-size: clamp(2rem, 4.5vw, 3.2rem);
        line-height: 1.08;
      }

      .section-copy {
        margin: 0;
        max-width: 68ch;
        color: var(--muted);
        font-size: clamp(0.96rem, 1.4vw, 1.08rem);
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(16, 72, 79, 0.22);
        color: var(--brand-strong);
        background: rgba(31, 111, 120, 0.08);
        border-radius: 999px;
        padding: 0.28rem 0.76rem;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.03em;
      }

      .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }

      .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 24px 0 34px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      @media (max-width: 900px) {
        .section-block {
          padding: 72px 0;
        }
      }

      @media (max-width: 640px) {
        .container-shell {
          width: min(1120px, 94vw);
        }

        .section-block {
          padding: 58px 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <slot />

    <script is:inline>
      (function () {
        var items = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window)) {
          items.forEach(function (el) {
            el.classList.add('in-view');
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );

        items.forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>