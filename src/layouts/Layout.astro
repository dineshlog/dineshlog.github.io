---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dinesh Loganathan | Information Security & Microsoft 365 Architect',
  description = 'Information Security Coordinator and Microsoft 365 Architect with 10+ years delivering secure workplace transformation across EMEA and APAC.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Dinesh Loganathan" />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#080c18" />

    <link rel="canonical" href="https://dineshlog.github.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dineshlog.github.io" />
    <meta property="og:image" content="https://dineshlog.github.io/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <style is:global>
      :root {
        --bg: #080c18;
        --surface: #0e1420;
        --surface-alt: #131928;
        --surface-hover: #192030;
        --text: #e2e8f2;
        --muted: #7a869e;
        --muted-lt: #9aa3b8;
        --line: rgba(201, 169, 110, 0.1);
        --line-subtle: rgba(255, 255, 255, 0.05);
        --brand: #c9a96e;
        --brand-strong: #d4af7a;
        --brand-dim: rgba(201, 169, 110, 0.07);
        --accent: #4d9bbf;
        --radius-lg: 22px;
        --radius-md: 14px;
        --radius-sm: 8px;
        --shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
        --shadow-gold: 0 0 60px rgba(201, 169, 110, 0.06);
        --glow-hover: 0 0 0 1px rgba(201, 169, 110, 0.25), 0 12px 40px rgba(201, 169, 110, 0.1);
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.65;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
      }

      .container-shell {
        width: min(1160px, 92vw);
        margin: 0 auto;
      }

      .section-block {
        padding: 110px 0;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-weight: 600;
        color: var(--brand);
      }

      .eyebrow::before {
        content: '';
        width: 24px;
        height: 1px;
        background: var(--brand);
        opacity: 0.6;
      }

      .section-title {
        margin: 16px 0 18px;
        font-family: 'Cormorant Garamond', serif;
        font-weight: 600;
        letter-spacing: -0.01em;
        font-size: clamp(2.2rem, 4vw, 3.4rem);
        line-height: 1.1;
        color: var(--text);
      }

      .section-copy {
        margin: 0;
        max-width: 60ch;
        color: var(--muted);
        font-size: clamp(0.94rem, 1.3vw, 1.04rem);
        line-height: 1.8;
        font-weight: 400;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(201, 169, 110, 0.18);
        color: var(--brand);
        background: rgba(201, 169, 110, 0.06);
        border-radius: 999px;
        padding: 0.28rem 0.75rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        font-family: 'DM Sans', sans-serif;
      }

      .reveal {
        opacity: 0;
        transform: translateY(26px);
        transition: opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1), transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
      }

      .site-footer {
        border-top: 1px solid var(--line-subtle);
        padding: 28px 0 40px;
        color: var(--muted);
        font-size: 0.84rem;
      }

      @media (max-width: 900px) {
        .section-block { padding: 84px 0; }
      }

      @media (max-width: 640px) {
        .section-block { padding: 64px 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .reveal { opacity: 1; transform: none; transition: none; }
      }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        var items = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window)) {
          items.forEach(function (el) { el.classList.add('in-view'); });
          return;
        }
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        items.forEach(function (el) { observer.observe(el); });
      })();
    </script>
  </body>
</html>
