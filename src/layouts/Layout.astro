---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Dinesh Loganathan | Microsoft 365 Expert & InfoSec Consultant',
  description = 'Security and privacy focused AI solutions and Modern Workspace consultant with 10+ years experience. Microsoft 365 Expert, InfoSec Specialist, Certified Trainer.',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Dinesh Loganathan" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dineshlog.github.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dineshlog.github.io" />
    <meta property="og:image" content="https://dineshlog.github.io/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=()" />
    <meta name="theme-color" content="#f8fafc" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --sidebar-w: 17rem;
        --accent: #2563eb;
        --accent-dim: rgba(37,99,235,0.08);
        --accent-glow: rgba(37,99,235,0.2);
      }
      .dark {
        --accent: #3b82f6;
        --accent-dim: rgba(59,130,246,0.12);
        --accent-glow: rgba(59,130,246,0.25);
      }
      * { box-sizing: border-box; }

      body {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      }

      .section-heading {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
      }

      .section-num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.6rem;
      }
      .section-num::before {
        content: '';
        display: inline-block;
        width: 1.25rem;
        height: 1px;
        background: var(--accent);
        opacity: 0.5;
        flex-shrink: 0;
      }

      .sidebar-texture {
        background-image: radial-gradient(circle, rgba(59,130,246,0.1) 1px, transparent 1px);
        background-size: 18px 18px;
      }

      .nav-active {
        color: var(--accent) !important;
        background: var(--accent-dim) !important;
        border-left-color: var(--accent) !important;
        font-weight: 600 !important;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        padding: 0.18rem 0.6rem;
        border-radius: 9999px;
        font-size: 0.7rem;
        font-weight: 500;
        font-family: 'IBM Plex Mono', monospace;
        border: 1px solid;
        white-space: nowrap;
        line-height: 1.4;
      }

      .card-lift {
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }
      .card-lift:hover { transform: translateY(-2px); }

      ::-webkit-scrollbar { width: 3px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: rgba(37,99,235,0.25); border-radius: 2px; }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
    <script is:inline>
      /* Light theme is default — only switch to dark if user explicitly chose it */
      (function () {
        try {
          if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-[#0a0f1e] text-slate-800 dark:text-slate-200 antialiased">
    <slot />
  </body>
</html>
